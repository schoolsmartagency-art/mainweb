<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Анна Алёшина</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ── TOKENS ─────────────────────────── */
:root {
  --ink:        #0A0F1E;
  --ink-mid:    #1C2236;
  --cream:      #F7F5F0;
  --cream-dim:  #EAE7DF;
  --gold:       #C9A84C;
  --gold-light: #E2C97A;
  --gold-dim:   #7A6128;
  --mist:       #8B8FA8;
  --mist-light: #C4C7D6;
  --line-dark:  rgba(255,255,255,0.1);
  --line-light: rgba(10,15,30,0.12);
  --r:          8px;
  --r-lg:       20px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'DM Sans', sans-serif;
  font-size: 16px;
  line-height: 1.7;
  color: var(--ink);
  background: var(--cream);
  overflow-x: hidden;
}
img { display: block; max-width: 100%; }
a { color: inherit; text-decoration: none; }
button { font-family: inherit; cursor: pointer; border: none; background: none; }
.container { max-width: 1200px; margin: 0 auto; padding: 0 48px; }

/* ── REVEAL ─── */
.reveal { opacity: 0; transform: translateY(28px); transition: opacity .75s ease, transform .75s ease; }
.reveal.left  { transform: translateX(-28px); }
.reveal.right { transform: translateX(28px); }
.reveal.visible { opacity: 1 !important; transform: none !important; }
.d1 { transition-delay: .1s; }
.d2 { transition-delay: .2s; }
.d3 { transition-delay: .3s; }
.d4 { transition-delay: .4s; }

/* ── HEADER ─── */
.header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  pointer-events: none; opacity: 0;
  transform: translateY(-100%);
  transition: opacity .4s, transform .4s, background .3s;
}
.header.scrolled {
  background: rgba(247,245,240,0.94);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--line-light);
  opacity: 1; transform: none; pointer-events: all;
}
.header-inner {
  max-width: 1200px; margin: 0 auto; padding: 0 48px;
  height: 68px; display: flex; align-items: center; justify-content: space-between;
}
.header-logo {
  font-family: 'Playfair Display', serif;
  font-size: 18px; font-weight: 700;
  color: var(--ink); letter-spacing: 0.02em;
  opacity: 0; transition: opacity .3s;
}
.header.scrolled .header-logo { opacity: 1; }
.nav-links { display: flex; gap: 36px; }
.nav-links a {
  font-size: 13px; font-weight: 500; letter-spacing: 0.06em;
  text-transform: uppercase; color: var(--mist);
  transition: color .2s;
}
.nav-links a:hover { color: var(--ink); }
.header-cta {
  font-size: 13px; font-weight: 600; letter-spacing: 0.04em;
  padding: 9px 24px; border: 1.5px solid var(--gold);
  color: var(--gold-dim); border-radius: 2px;
  transition: all .2s;
}
.header-cta:hover { background: var(--gold); color: #fff; }

.burger { display: none; flex-direction: column; gap: 6px; padding: 6px; }
.burger span { display: block; width: 24px; height: 1.5px; background: var(--ink); transition: all .3s; }
.burger.open span:nth-child(1) { transform: translateY(7.5px) rotate(45deg); }
.burger.open span:nth-child(2) { opacity: 0; }
.burger.open span:nth-child(3) { transform: translateY(-7.5px) rotate(-45deg); }
.mobile-menu {
  position: fixed; inset: 0; z-index: 190;
  background: var(--ink); display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 40px;
  opacity: 0; pointer-events: none; transition: opacity .3s;
}
.mobile-menu.open { opacity: 1; pointer-events: all; }
.mobile-menu a { font-family: 'Playfair Display', serif; font-size: 36px; font-weight: 700; color: var(--cream); letter-spacing: -0.5px; }
.mobile-menu a:hover { color: var(--gold); }

/* ── HERO ─── */
.hero {
  min-height: 100vh;
  background: var(--ink);
  display: grid; grid-template-columns: 1fr 680px;
  position: relative;
  overflow: hidden;
}
.hero-left {
  display: flex; flex-direction: column; justify-content: center;
  padding: 120px 60px 100px max(48px, calc((100vw - 1200px)/2 + 48px));
  position: relative;
}
.hero-kicker {
  font-size: 11px; font-weight: 600; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--gold);
  margin-bottom: 40px;
  display: flex; align-items: center; gap: 16px;
  opacity: 0; animation: fadeUp .8s .4s forwards;
}
.hero-kicker::before {
  content: ''; display: block; width: 32px; height: 1px; background: var(--gold); flex-shrink: 0;
}
.hero-name {
  font-family: 'Playfair Display', serif;
  font-size: clamp(64px, 8vw, 108px);
  font-weight: 900; line-height: 0.92;
  letter-spacing: -2px; color: var(--cream);
  margin-bottom: 36px;
  opacity: 0; animation: fadeUp .9s .6s forwards;
}
.hero-name em {
  font-style: italic; color: var(--gold-light);
}
.hero-desc {
  font-size: 16px; font-weight: 300; color: var(--mist-light);
  max-width: 420px; line-height: 1.85;
  margin-bottom: 52px;
  opacity: 0; animation: fadeUp .8s .8s forwards;
}
.hero-actions {
  display: flex; gap: 16px; flex-wrap: wrap;
  opacity: 0; animation: fadeUp .8s 1s forwards;
}
.btn {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 14px 32px; border-radius: 2px;
  font-size: 13px; font-weight: 600; letter-spacing: 0.06em;
  text-transform: uppercase; transition: all .22s;
}
.btn-gold { background: var(--gold); color: var(--ink); }
.btn-gold:hover { background: var(--gold-light); }
.btn-outline { border: 1.5px solid rgba(255,255,255,0.2); color: var(--cream); }
.btn-outline:hover { border-color: var(--gold); color: var(--gold); }

.hero-right {
  position: relative; overflow: hidden;
}
.hero-photo-main {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center top;
}
.hero-photo-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to right, var(--ink) 0%, transparent 35%);
  pointer-events: none;
}
.hero-badges {
  position: absolute; bottom: 48px; right: 32px;
  display: flex; flex-direction: column; gap: 12px;
  opacity: 0; animation: fadeUp .8s 1.2s forwards;
}
.hero-badge {
  background: var(--cream); border-radius: 2px;
  padding: 14px 22px 14px 24px;
  border-left: 3px solid var(--gold);
  box-shadow: 0 8px 32px rgba(0,0,0,.35);
}
.hero-badge-num {
  font-family: 'Playfair Display', serif;
  font-size: 26px; font-weight: 700; letter-spacing: -1px; line-height: 1;
  color: var(--ink);
}
.hero-badge-label { font-size: 11px; color: var(--mist); margin-top: 3px; letter-spacing: 0.04em; }

/* ── SECTION ─── */
.section { padding: 104px 0; }
.section-dark { background: var(--ink); }
.section-dim { background: var(--cream-dim); }

.label {
  font-size: 11px; font-weight: 600; letter-spacing: 0.16em;
  text-transform: uppercase; color: var(--gold-dim);
  display: flex; align-items: center; gap: 14px;
  margin-bottom: 24px;
}
.label::before { content: ''; display: block; width: 28px; height: 1px; background: var(--gold); flex-shrink: 0; }
.label-light { color: var(--gold-light); }
.label-light::before { background: var(--gold-light); }

.section-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(36px, 4vw, 56px);
  font-weight: 700; line-height: 1.08; letter-spacing: -0.5px;
  color: var(--ink); margin-bottom: 20px;
}
.section-title-light { color: var(--cream); }
.muted { color: var(--mist); }

/* ── PROJECTS ─── */
.projects-section { padding: 104px 0; background: var(--cream); }
.projects-list { margin-top: 56px; }
.project-card {
  display: grid; grid-template-columns: 56px 1fr auto;
  gap: 0 40px; padding: 52px 0;
  border-top: 1px solid var(--line-light);
  align-items: start;
}
.project-card:last-child { border-bottom: 1px solid var(--line-light); }
.project-num {
  font-family: 'Playfair Display', serif;
  font-size: 13px; font-weight: 400; color: var(--gold);
  letter-spacing: 0.08em; padding-top: 8px;
}
.project-body { display: flex; flex-direction: column; gap: 16px; }
.project-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(24px, 2.8vw, 36px);
  font-weight: 700; letter-spacing: -0.3px; line-height: 1.12;
  color: var(--ink);
}
.project-sub {
  font-size: 12px; font-weight: 600; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--gold-dim);
}
.project-desc { font-size: 15px; color: var(--mist); line-height: 1.8; max-width: 640px; }
.project-stats { display: flex; gap: 40px; padding-top: 8px; }
.proj-stat-num {
  font-family: 'Playfair Display', serif;
  font-size: 28px; font-weight: 700; letter-spacing: -1px; line-height: 1;
  color: var(--ink);
}
.proj-stat-label { font-size: 11px; color: var(--mist); margin-top: 4px; line-height: 1.4; }
.project-arrow {
  display: flex; align-items: center; justify-content: center;
  width: 52px; height: 52px; border-radius: 50%;
  border: 1.5px solid var(--line-light);
  color: var(--ink); flex-shrink: 0;
  transition: all .22s; margin-top: 6px;
}
.project-arrow:hover { background: var(--ink); border-color: var(--ink); color: var(--cream); transform: rotate(45deg); }

/* ── ABOUT ─── */
.about-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 100px; align-items: center;
}
.about-photo-wrap { position: relative; }
.about-photo-img {
  width: 100%; aspect-ratio: 3/4;
  object-fit: cover; object-position: center top;
  border-radius: 4px;
}
/* Gold frame offset decoration */
.about-photo-wrap::before {
  content: '';
  position: absolute;
  inset: -16px -16px auto auto;
  width: 60%; height: 60%;
  border-top: 2px solid var(--gold);
  border-right: 2px solid var(--gold);
  border-radius: 4px;
  opacity: 0.4; pointer-events: none;
}
.about-photo-wrap::after {
  content: '';
  position: absolute;
  inset: auto auto -16px -16px;
  width: 40%; height: 40%;
  border-bottom: 2px solid var(--gold);
  border-left: 2px solid var(--gold);
  border-radius: 4px;
  opacity: 0.4; pointer-events: none;
}
.about-chip {
  position: absolute; bottom: 32px; right: -28px;
  background: var(--ink); border-radius: 4px;
  padding: 18px 24px; border-left: 3px solid var(--gold);
  box-shadow: 0 12px 40px rgba(0,0,0,.25);
}
.about-chip-num {
  font-family: 'Playfair Display', serif;
  font-size: 22px; font-weight: 700; letter-spacing: 0.03em; line-height: 1;
  color: var(--gold);
}
.about-chip-label { font-size: 11px; color: var(--mist-light); margin-top: 4px; }
.about-text { display: flex; flex-direction: column; gap: 24px; }
.about-lead {
  font-family: 'Playfair Display', serif;
  font-size: clamp(24px, 2.5vw, 32px); font-weight: 700; line-height: 1.25;
  letter-spacing: -0.3px; color: var(--ink);
}
.about-body { font-size: 15px; color: var(--mist); line-height: 1.85; }
.about-tags { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 8px; }
.about-tag {
  font-size: 12px; font-weight: 500; letter-spacing: 0.06em;
  padding: 7px 18px; border-radius: 2px;
  border: 1px solid var(--line-light); color: var(--mist);
  background: transparent;
}

/* ── STATS ─── */
.stats-bar { padding: 72px 0; background: var(--ink); border: none; }
.stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; }
.stat-item {
  padding: 36px 32px;
  border-right: 1px solid var(--line-dark);
}
.stat-item:last-child { border-right: none; }
.stat-num {
  font-family: 'Playfair Display', serif;
  font-size: clamp(40px, 4.5vw, 60px); font-weight: 900;
  letter-spacing: -2px; line-height: 1; color: var(--cream);
}
.stat-desc { font-size: 13px; color: var(--mist); margin-top: 10px; line-height: 1.55; }

/* ── REVIEWS ─── */
.reviews-intro { margin-bottom: 48px; }
.reviews-with-nav { display: flex; align-items: center; gap: 20px; }
.reviews-nav-btn {
  width: 52px; height: 52px; border-radius: 50%;
  border: 1.5px solid var(--line-light); background: var(--cream);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: all .2s; color: var(--ink); flex-shrink: 0;
}
.reviews-nav-btn:hover:not(:disabled) { background: var(--ink); border-color: var(--ink); color: var(--cream); }
.reviews-nav-btn:disabled { opacity: 0.2; cursor: default; }
.reviews-track-outer { overflow: hidden; flex: 1; cursor: grab; }
.reviews-track-outer:active { cursor: grabbing; }
.reviews-track {
  display: flex; gap: 24px;
  overflow-x: auto; scrollbar-width: none;
  -webkit-overflow-scrolling: touch; padding-bottom: 8px;
  touch-action: pan-x;
}
.reviews-track::-webkit-scrollbar { display: none; }
.review-card {
  flex: 0 0 300px; height: 390px;
  background: var(--cream); border: 1px solid var(--line-light);
  border-radius: 4px; overflow: hidden;
  transition: box-shadow .3s, transform .3s; cursor: zoom-in;
}
.review-card:hover { box-shadow: 0 16px 48px rgba(10,15,30,.12); transform: translateY(-3px); }
.review-img-wrap { width: 100%; height: 100%; overflow: hidden; }
.review-img-wrap img {
  width: 100%; height: 100%; object-fit: cover; object-position: top;
  display: block; transition: transform .4s ease;
}
.review-card:hover .review-img-wrap img { transform: scale(1.04); }

/* ── BOOKS ─── */
.books-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-top: 48px;
}
.book-card {
  background: var(--cream); border: 1px solid var(--line-light);
  border-radius: 4px; overflow: hidden;
  transition: box-shadow .3s, transform .3s;
}
.book-card:hover { box-shadow: 0 12px 36px rgba(10,15,30,.10); transform: translateY(-2px); }
.book-img { width: 100%; aspect-ratio: 3/4; background: var(--cream-dim); }
.book-img img { width: 100%; height: 100%; object-fit: cover; }
.book-label {
  padding: 18px 20px; font-size: 13px; font-weight: 500;
  line-height: 1.5; color: var(--ink);
}
.book-grade { font-size: 11px; color: var(--mist); margin-top: 5px; letter-spacing: 0.03em; }

/* ── VIDEO + SOCIALS ─── */
.video-socials-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
.video-card { border-radius: 4px; overflow: hidden; border: 1px solid var(--line-dark); }
.video-embed-wrap { position: relative; padding-bottom: 56.25%; height: 0; }
.video-embed-wrap iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; }
.video-caption {
  padding: 20px 24px; background: rgba(255,255,255,0.05);
  border-top: 1px solid var(--line-dark);
}
.video-caption strong {
  font-family: 'Playfair Display', serif;
  font-size: 15px; font-weight: 600; color: var(--cream); display: block; margin-bottom: 4px;
}
.video-caption span { font-size: 12px; color: var(--mist); }

.socials-col { display: flex; flex-direction: column; gap: 14px; }
.social-card {
  display: flex; align-items: center; gap: 20px;
  padding: 22px 26px; border-radius: 4px;
  border: 1px solid var(--line-dark); background: rgba(255,255,255,.03);
  color: var(--cream); transition: all .22s;
}
.social-card:hover { border-color: var(--gold); background: rgba(201,168,76,.06); }
.social-card-icon {
  width: 46px; height: 46px; border-radius: 4px;
  background: rgba(255,255,255,.07);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  color: var(--mist-light);
}
.social-card-name {
  font-family: 'Playfair Display', serif;
  font-size: 16px; font-weight: 600; color: var(--cream);
}
.social-card-sub { font-size: 12px; color: var(--mist); margin-top: 2px; }
.social-card-arrow { margin-left: auto; color: var(--mist); flex-shrink: 0; transition: color .2s; }
.social-card:hover .social-card-arrow { color: var(--gold); }

/* ── CONTACT ─── */
.contact-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: stretch; }
.contact-photo { border-radius: 4px; overflow: hidden; position: relative; min-height: 400px; }
.contact-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }
/* Thin gold right border on contact photo */
.contact-photo::after {
  content: '';
  position: absolute; inset: 0; right: -8px; top: 8px;
  border: 1.5px solid var(--gold); border-radius: 4px;
  opacity: 0.3; pointer-events: none;
}
.contact-form-side { padding-top: 12px; }
.contact-lead {
  font-family: 'Playfair Display', serif;
  font-size: clamp(28px, 3vw, 42px); font-weight: 700;
  letter-spacing: -0.5px; line-height: 1.15;
  margin-bottom: 14px; color: var(--ink);
}
.contact-sub {
  font-size: 15px; color: var(--mist); font-weight: 300;
  margin-bottom: 40px; line-height: 1.75;
}
.form-field { display: flex; flex-direction: column; gap: 7px; margin-bottom: 18px; }
.form-field label {
  font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--mist);
}
.form-field input,
.form-field select,
.form-field textarea {
  font-family: 'DM Sans', sans-serif;
  font-size: 15px; font-weight: 300;
  padding: 14px 18px;
  border: 1.5px solid var(--line-light);
  border-radius: 2px; outline: none;
  background: transparent; color: var(--ink);
  transition: border-color .2s;
  width: 100%;
}
.form-field input:focus,
.form-field select:focus,
.form-field textarea:focus { border-color: var(--gold); }
.form-field textarea { resize: vertical; min-height: 108px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.form-error-msg { font-size: 12px; color: #c0392b; display: none; margin-top: -12px; }
.field-err input, .field-err select { border-color: #c0392b; }
.field-err .form-error-msg { display: block; }
.btn-submit {
  width: 100%; padding: 16px; justify-content: center;
  font-size: 13px;
}
.form-success {
  display: none; padding: 36px; background: #f0f8e8;
  border-left: 3px solid #7BC73D; border-radius: 4px;
}
.form-success h3 {
  font-family: 'Playfair Display', serif;
  font-size: 20px; font-weight: 700; margin-bottom: 8px;
}
.form-success p { color: var(--mist); font-size: 15px; }

/* ── FOOTER ─── */
.footer { background: var(--ink); color: rgba(255,255,255,.35); padding: 64px 0 44px; }
.footer-top {
  display: grid; grid-template-columns: 1fr 1fr 1fr;
  gap: 48px; padding-bottom: 48px;
  border-bottom: 1px solid var(--line-dark); margin-bottom: 36px;
}
.footer-name {
  font-family: 'Playfair Display', serif;
  font-size: 22px; font-weight: 700; color: var(--cream);
  letter-spacing: 0.02em; display: block; margin-bottom: 10px;
}
.footer-tagline { font-size: 13px; color: rgba(255,255,255,.3); line-height: 1.7; }
.footer-col-title {
  font-size: 10px; font-weight: 600; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--gold); margin-bottom: 16px;
}
.footer-col a { display: block; font-size: 14px; color: rgba(255,255,255,.4); margin-bottom: 10px; transition: color .2s; }
.footer-col a:hover { color: var(--gold-light); }
.footer-bottom { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
.footer-copy { font-size: 12px; color: rgba(255,255,255,.2); }

/* ── MODAL ─── */
.img-modal {
  position: fixed; inset: 0; background: rgba(10,15,30,.9);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; pointer-events: none; transition: .25s ease; z-index: 9999;
}
.img-modal.active { opacity: 1; pointer-events: auto; }
.img-modal-content { position: relative; max-width: 92vw; max-height: 92vh; }
.img-modal-content img {
  max-width: 92vw; max-height: 92vh;
  object-fit: contain; border-radius: 4px;
  box-shadow: 0 20px 80px rgba(0,0,0,.7);
}
.img-modal-close {
  position: absolute; top: -16px; right: -16px;
  width: 40px; height: 40px; border-radius: 50%;
  background: var(--cream); border: none; cursor: pointer;
  font-size: 22px; display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 16px rgba(0,0,0,.3);
  font-family: 'DM Sans', sans-serif; line-height: 1;
}

/* ── HORIZONTAL RULE ─── */
.hr-gold { height: 1px; background: linear-gradient(to right, transparent, var(--gold) 40%, var(--gold) 60%, transparent); opacity: 0.2; margin: 0; }

/* ── KEYFRAMES ─── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(22px); }
  to   { opacity: 1; transform: none; }
}

/* ── RESPONSIVE ─── */
@media (max-width: 1024px) {
  .hero { grid-template-columns: 1fr; min-height: auto; }
  .hero::before { display: none; }
  .hero-left { padding: 100px 48px 60px; }
