<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Татьяна Карлова — репетитор по математике</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Geologica:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
    --rose-50: #FBF0F0;
    --rose-100: #F5D9D9;
    --rose-200: #EBB9B9;
    --rose-400: #D49191;
    --rose-600: #B86B6B;
    --rose-800: #9A4F4F;
    --peach: #FBE0D2;
    --dusty-rose: #E0B4B4;
    --bg: #FDF9F9;
    --white: #ffffff;
    --text: #3D2C2C;
    --text-soft: #6E5D5D;
    --text-muted: #9E8E8E;
    --border: rgba(154, 79, 79, 0.12);
    --font-display: 'Playfair Display', Georgia, serif;
    --font-body: 'Geologica', sans-serif;
    --radius: 16px;
    --shadow: 0 4px 32px rgba(154, 79, 79, 0.08);
}
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
    font-size: 16px;
    line-height: 1.7;
    overflow-x: hidden;
  }

  :root {
    --page-padding: 5vw;
  }

  /* NAV - glass/semi-transparent */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(253,249,249,0.72);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
    border-bottom: 1px solid rgba(154,79,79,0.10);
    box-shadow: 0 2px 20px rgba(154,79,79,0.06);
    padding: 0 var(--page-padding);
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--rose-600);
    text-decoration: none;
    font-weight: 700;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }
  .nav-links a {
    text-decoration: none;
    color: var(--text-soft);
    font-size: 0.9rem;
    font-weight: 400;
    transition: color 0.2s;
    letter-spacing: 0.02em;
  }
  .nav-links a:hover { color: var(--rose-400); }
  .nav-cta {
    background: var(--rose-400);
    color: white !important;
    padding: 0.45rem 1.2rem;
    border-radius: 40px;
    font-weight: 500 !important;
  }
  .nav-cta:hover { background: var(--rose-600) !important; color: white !important; }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 96px var(--page-padding) 64px;
    gap: 4rem;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -200px; right: -200px;
    width: 700px; height: 700px;
    background: radial-gradient(circle, var(--rose-50) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-tag {
    display: inline-block;
    background: var(--rose-50);
    color: var(--rose-600);
    border: 1px solid var(--rose-100);
    padding: 0.3rem 1rem;
    border-radius: 40px;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    animation: tag-blink 2s ease-in-out infinite;
  }
  @keyframes tag-blink {
    0%, 100% {
      color: var(--rose-600);
      border-color: var(--rose-100);
      background: var(--rose-50);
      box-shadow: none;
    }
    50% {
      color: var(--rose-400);
      border-color: var(--rose-400);
      background: rgba(212,145,145,0.14);
      box-shadow: 0 0 14px rgba(212,145,145,0.35);
    }
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    line-height: 1.15;
    margin-bottom: 1.5rem;
    color: var(--text);
  }
  .hero h1 em {
    color: var(--rose-400);
    font-style: italic;
  }
  .hero-desc {
    color: var(--text-soft);
    font-size: 1.05rem;
    margin-bottom: 2rem;
    max-width: 480px;
    font-weight: 300;
    line-height: 1.8;
  }
  .hero-btns {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--rose-400);
    color: white;
    padding: 0.85rem 2rem;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    transition: background 0.2s, transform 0.15s;
    display: inline-block;
  }
  .btn-primary:hover { background: var(--rose-600); transform: translateY(-2px); }
  .btn-outline {
    border: 1.5px solid var(--rose-400);
    color: var(--rose-400);
    padding: 0.85rem 2rem;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    transition: all 0.2s;
    display: inline-block;
  }
  .btn-outline:hover { background: var(--rose-50); transform: translateY(-2px); }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }
  .avatar-frame {
    width: 380px; height: 440px;
    background: linear-gradient(145deg, var(--rose-50), var(--rose-100));
    border-radius: 40% 60% 60% 40% / 50% 40% 60% 50%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    overflow: hidden;
    position: relative;
    border: 2px solid var(--rose-100);
  }
  .avatar-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    display: block;
  }
  .hero-photo-mobile {
    display: none;
    width: min(200px, 52vw);
    margin: 0 auto 1rem;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    border: 2px solid var(--rose-100);
    box-shadow: var(--shadow);
  }
  .hero-photo-mobile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    display: block;
  }
  .avatar-placeholder {
    width: 100%; height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 1rem;
  }
  .avatar-initials {
    width: 110px; height: 110px;
    background: var(--rose-400);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 2.4rem;
    color: white;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .avatar-name-tag {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--rose-800);
    font-weight: 700;
    text-align: center;
  }
  .avatar-sub {
    font-size: 0.85rem;
    color: var(--rose-600);
    text-align: center;
  }

  .stat-badges {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .stat-badges.left { left: -30px; top: 50%; transform: translateY(-50%); }
  .stat-badges.right { right: -30px; top: 40%; transform: translateY(-50%); }
  .stat-badge {
    background: white;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.7rem 1.1rem;
    box-shadow: var(--shadow);
    text-align: center;
    white-space: nowrap;
  }
  .stat-badge strong {
    display: block;
    font-family: var(--font-body);
    font-size: 1.6rem;
    color: var(--rose-400);
    font-weight: 600;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .stat-badge span {
    font-size: 0.72rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-stats-mobile { display: none; }

  /* SECTION */
  section {
    padding: 96px var(--page-padding);
  }
  .section-label {
    display: inline-block;
    background: var(--rose-50);
    color: var(--rose-600);
    border: 1px solid var(--rose-100);
    padding: 0.3rem 1rem;
    border-radius: 40px;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.2;
    margin-bottom: 1rem;
    color: var(--text);
  }
  .section-title em { color: var(--rose-400); font-style: italic; }
  .section-sub {
    color: var(--text-soft);
    max-width: 540px;
    font-weight: 300;
    font-size: 1.05rem;
  }
  .section-header { margin-bottom: 3.5rem; }
  .form-title em { display: inline; }

  /* ABOUT */
  .about-grid {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 4rem;
    align-items: center;
    max-width: 960px;
    margin: 0 auto;
  }
  .about-photo-wrap {
    border-radius: 24px;
    overflow: hidden;
    border: 2px solid var(--rose-100);
    box-shadow: var(--shadow);
    aspect-ratio: 4 / 5;
    background: var(--rose-50);
  }
  .about-photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
  }

  .about-text p {
    color: var(--text-soft);
    font-weight: 300;
    margin-bottom: 1.2rem;
    line-height: 1.85;
    font-size: 1.05rem;
  }
  .about-highlight {
    background: var(--rose-50);
    border-left: 3px solid var(--rose-400);
    padding: 1rem 1.5rem;
    border-radius: 0 12px 12px 0;
    margin: 1.5rem 0;
  }
  .about-highlight p {
    color: var(--rose-800) !important;
    font-weight: 400 !important;
    font-size: 1rem !important;
    margin: 0 !important;
    font-style: italic;
  }

  /* RESULTS STATS */
  .stats-bg {
    background: var(--rose-800);
    color: white;
    padding: 80px var(--page-padding);
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-top: 2.5rem;
  }
  .stat-card {
    text-align: center;
    padding: 2rem 1.5rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .stat-num {
    font-family: var(--font-body);
    font-size: 3rem;
    font-weight: 600;
    color: var(--peach);
    line-height: 1;
    height: 3.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    font-variant-numeric: tabular-nums;
  }
  .stat-label {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.4;
    font-weight: 300;
    margin: 0;
  }
  .stats-bg .section-title { color: white; }
  .stats-bg .section-sub { color: rgba(255,255,255,0.65); }
  .stats-bg .section-label { background: rgba(255,255,255,0.1); color: var(--peach); border-color: rgba(255,255,255,0.2); }

  /* SERVICES */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .service-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem 1.75rem;
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
  }
  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
  }
  .service-card.featured {
    background: var(--rose-400);
    border-color: var(--rose-400);
    color: white;
  }
  .service-tag {
    display: inline-block;
    background: var(--rose-50);
    color: var(--rose-600);
    font-size: 0.75rem;
    padding: 0.2rem 0.7rem;
    border-radius: 40px;
    margin-bottom: 1rem;
    font-weight: 500;
  }
  .service-card h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    font-weight: 700;
  }
  .service-card.featured h3 { color: white; }
  .service-card p {
    font-size: 0.9rem;
    color: var(--text-soft);
    font-weight: 300;
    line-height: 1.6;
    margin-bottom: 1.25rem;
    flex: 1;
  }
  .service-card.featured p { color: rgba(255,255,255,0.85); }
  .price-line {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }
  .service-card.featured .price-line {
    border-top-color: rgba(255,255,255,0.22);
  }
  .price-amount {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .service-card.featured .price-amount { color: white; }
  .price-duration {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-weight: 400;
    white-space: nowrap;
  }
  .service-card.featured .price-duration { color: rgba(255,255,255,0.72); }
  .service-card.featured .service-tag {
    background: rgba(255,255,255,0.2);
    color: white;
  }

  /* HOW LESSONS WORK */
  .lessons-section {
    background: var(--rose-50);
    border-radius: 32px;
    max-width: 960px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }
  .lessons-section .section-header {
    margin-bottom: 2.5rem;
  }
  .lessons-video-wrap {
    width: 100%;
    margin: 0 auto;
    border-radius: 20px;
    overflow: hidden;
    border: 2px solid var(--rose-100);
    box-shadow: var(--shadow);
    background: var(--rose-800);
    aspect-ratio: 16 / 9;
  }
  .lessons-video-wrap video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    background: #000;
  }
  .lessons-note { display: none; }

  /* HOW IT WORKS */
  .steps-block {
    display: block;
    margin-top: 3rem;
  }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    position: relative;
  }
  .steps-grid::before {
    content: '';
    position: absolute;
    top: 56px;
    left: calc(12.5% + 1rem);
    right: calc(12.5% + 1rem);
    height: 1px;
    background: linear-gradient(to right, var(--rose-100), var(--rose-200), var(--rose-100));
  }
  .step-item { text-align: center; }
  .step-num {
    width: 112px;
    height: 112px;
    background: white;
    border: 2px solid var(--rose-200);
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-family: var(--font-body);
    font-size: 2.4rem;
    font-weight: 600;
    line-height: 1;
    color: var(--rose-400);
    margin: 0 auto 1.25rem;
    position: relative;
    z-index: 1;
    padding: 0;
    font-variant-numeric: tabular-nums;
    box-sizing: border-box;
  }
  .step-item h4 {
    font-weight: 500;
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }
  .step-item p {
    font-size: 0.85rem;
    color: var(--text-soft);
    font-weight: 300;
    line-height: 1.5;
  }

  /* REVIEWS */
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .review-screenshot-card {
    display: block;
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
  }
  .review-screenshot-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(154,79,79,0.14);
  }
  .review-screenshot-card img {
    width: 100%;
    height: auto;
    display: block;
  }
  .reviews-cta {
    text-align: center;
    margin-top: 2.5rem;
  }
  .reviews-cta a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .reviews-profi-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--rose-50);
    color: var(--rose-600);
    border: 1px solid var(--rose-100);
    padding: 0.35rem 0.9rem;
    border-radius: 40px;
    font-size: 0.8rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  /* FORM */
  .form-section {
    background: white;
    border-radius: 24px;
    padding: 4rem var(--page-padding);
    border: 1px solid var(--border);
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
    box-sizing: border-box;
  }
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    min-width: 0;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }
  .form-group.full { grid-column: 1 / -1; }
  .form-group:has(.select-wrap) { grid-column: 1 / -1; }
  label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-soft);
    letter-spacing: 0.02em;
  }
  input, select, textarea {
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text);
    background: var(--bg);
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    outline: none;
    width: 100%;
  }
  input:focus, select:focus, textarea:focus {
    border-color: var(--rose-400);
    background: white;
    box-shadow: 0 0 0 3px rgba(212,145,145,0.12);
  }
  .select-wrap {
    position: relative;
    width: 100%;
    max-width: 100%;
    min-width: 0;
  }
  .select-wrap select {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }
  .select-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text);
    background: var(--bg);
    cursor: pointer;
    text-align: left;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
  }
  .select-trigger.placeholder { color: var(--text-muted); }
  .select-trigger:focus {
    outline: none;
    border-color: var(--rose-400);
    background: white;
    box-shadow: 0 0 0 3px rgba(212,145,145,0.12);
  }
  .select-trigger.error { border-color: #E24B4A; }
  .select-trigger-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
    flex: 1;
  }
  .select-chevron {
    flex-shrink: 0;
    width: 10px;
    height: 10px;
    border-right: 2px solid var(--rose-400);
    border-bottom: 2px solid var(--rose-400);
    transform: rotate(45deg) translateY(-2px);
    transition: transform 0.2s;
  }
  .select-wrap.open .select-chevron {
    transform: rotate(-135deg) translateY(2px);
  }
  .select-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    width: 100%;
    box-sizing: border-box;
    background: white;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(154,79,79,0.12);
    z-index: 50;
    max-height: 240px;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  .select-wrap.open .select-dropdown { display: block; }
  .select-option {
    display: block;
    width: 100%;
    padding: 0.75rem 1rem;
    border: none;
    background: none;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text);
    text-align: left;
    cursor: pointer;
    transition: background 0.15s;
  }
  .select-option:hover,
  .select-option:focus {
    background: var(--rose-50);
    outline: none;
  }
  .select-option.selected {
    background: var(--rose-50);
    color: var(--rose-600);
    font-weight: 500;
  }
  textarea { resize: vertical; min-height: 100px; }
  .form-submit {
    margin-top: 2rem;
    text-align: center;
  }
  .form-submit button {
    background: var(--rose-400);
    color: white;
    border: none;
    padding: 1.05rem 2rem;
    border-radius: 40px;
    font-family: var(--font-body);
    font-size: 1.05rem;
