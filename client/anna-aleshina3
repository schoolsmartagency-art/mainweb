<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Анна Алёшина</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ── TOKENS ─────────────────────────── */
:root {
  --bg:         #F5EDE6;
  --bg-warm:    #EEE2D8;
  --bg-dark:    #1E1410;
  --bg-mid:     #2E1F18;
  --terra:      #C4674A;
  --terra-dark: #A35038;
  --terra-pale: #E8A898;
  --rose:       #D4A5A0;
  --rose-light: #EDD5D0;
  --ink:        #1E1410;
  --ink-soft:   #5C4A42;
  --ink-faint:  #A89490;
  --line:       rgba(30,20,16,0.12);
  --line-warm:  rgba(196,103,74,0.2);
  --line-dark:  rgba(255,255,255,0.1);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'DM Sans', sans-serif;
  font-size: 16px; line-height: 1.7;
  color: var(--ink); background: var(--bg);
  overflow-x: hidden;
}
img { display: block; max-width: 100%; }
a { color: inherit; text-decoration: none; }
button { font-family: inherit; cursor: pointer; border: none; background: none; }
.container { max-width: 1200px; margin: 0 auto; padding: 0 48px; }

/* ── REVEAL ─── */
.reveal { opacity: 0; transform: translateY(24px); transition: opacity .7s ease, transform .7s ease; }
.reveal.left  { transform: translateX(-24px); }
.reveal.right { transform: translateX(24px); }
.reveal.visible { opacity: 1 !important; transform: none !important; }
.d1 { transition-delay: .1s; }
.d2 { transition-delay: .2s; }
.d3 { transition-delay: .3s; }
.d4 { transition-delay: .4s; }

/* ── HEADER ─── */
.header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  pointer-events: none; opacity: 0; transform: translateY(-100%);
  transition: opacity .4s, transform .4s, background .3s;
}
.header.scrolled {
  background: rgba(245,237,230,0.95);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--line);
  opacity: 1; transform: none; pointer-events: all;
}
.header-inner {
  max-width: 1200px; margin: 0 auto; padding: 0 48px;
  height: 68px; display: flex; align-items: center; justify-content: space-between;
}
.header-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px; font-weight: 600; color: var(--ink); letter-spacing: 0.02em;
  opacity: 0; transition: opacity .3s;
}
.header.scrolled .header-logo { opacity: 1; }
.nav-links { display: flex; gap: 36px; }
.nav-links a {
  font-size: 13px; font-weight: 500; letter-spacing: 0.05em;
  text-transform: uppercase; color: var(--ink-soft); transition: color .2s;
}
.nav-links a:hover { color: var(--terra); }
.header-cta {
  font-size: 13px; font-weight: 600; letter-spacing: 0.04em;
  padding: 9px 24px; border: 1.5px solid var(--terra);
  color: var(--terra); border-radius: 100px; transition: all .2s;
}
.header-cta:hover { background: var(--terra); color: #fff; }

.burger { display: none; flex-direction: column; gap: 5px; padding: 6px; }
.burger span { display: block; width: 22px; height: 1.5px; background: var(--ink); transition: all .3s; }
.burger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.burger.open span:nth-child(2) { opacity: 0; }
.burger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
.mobile-menu {
  position: fixed; inset: 0; z-index: 190;
  background: var(--bg-dark); display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 40px;
  opacity: 0; pointer-events: none; transition: opacity .3s;
}
.mobile-menu.open { opacity: 1; pointer-events: all; }
.mobile-menu a {
  font-family: 'Cormorant Garamond', serif; font-size: 40px; font-weight: 600;
  color: var(--bg); letter-spacing: -0.5px;
}
.mobile-menu a:hover { color: var(--terra-pale); }

/* ── HERO ─── */
.hero {
  min-height: 100vh;
  display: grid; grid-template-columns: 1fr 580px;
  overflow: hidden; background: var(--bg);
}
.hero-left {
  display: flex; flex-direction: column; justify-content: center;
  padding: 120px 64px 100px max(48px, calc((100vw - 1200px)/2 + 48px));
  position: relative;
}
/* Subtle warm texture stripe */
.hero-left::after {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(to right, var(--terra), transparent);
  opacity: 0.4;
}
.hero-kicker {
  font-size: 11px; font-weight: 500; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--terra);
  margin-bottom: 32px;
  display: flex; align-items: center; gap: 14px;
  opacity: 0; animation: fadeUp .7s .3s forwards;
}
.hero-kicker::before {
  content: ''; display: block; width: 28px; height: 1px;
  background: var(--terra); flex-shrink: 0;
}
.hero-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(72px, 9vw, 120px);
  font-weight: 300; line-height: 0.9;
  letter-spacing: -1px; color: var(--ink);
  margin-bottom: 32px;
  opacity: 0; animation: fadeUp .9s .5s forwards;
}
.hero-name em {
  font-style: italic; color: var(--terra);
  font-weight: 300;
}
.hero-desc {
  font-size: 16px; font-weight: 300; color: var(--ink-soft);
  max-width: 400px; line-height: 1.85; margin-bottom: 48px;
  opacity: 0; animation: fadeUp .7s .7s forwards;
}
.hero-actions {
  display: flex; gap: 14px; flex-wrap: wrap;
  opacity: 0; animation: fadeUp .7s .9s forwards;
}
.btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 13px 28px; border-radius: 100px;
  font-size: 13px; font-weight: 500; letter-spacing: 0.04em;
  transition: all .2s;
}
.btn-terra { background: var(--terra); color: #fff; }
.btn-terra:hover { background: var(--terra-dark); }
.btn-ghost {
  border: 1.5px solid var(--line-warm);
  color: var(--ink-soft); background: transparent;
}
.btn-ghost:hover { border-color: var(--terra); color: var(--terra); }

.hero-right {
  position: relative; overflow: hidden;
}
.hero-photo-main {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center top;
}
/* Soft left fade so photo blends into bg */
.hero-photo-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to right, var(--bg) 0%, rgba(245,237,230,0.2) 30%, transparent 55%);
  pointer-events: none;
}

/* ── SECTION ─── */
.section { padding: 100px 0; }
.section-warm { background: var(--bg-warm); }
.section-dark { background: var(--bg-dark); }

/* Section heading style */
.sec-label {
  font-size: 11px; font-weight: 500; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--terra);
  margin-bottom: 20px; display: block;
}
.section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(38px, 4.5vw, 60px);
  font-weight: 400; line-height: 1.05; letter-spacing: -0.3px;
  color: var(--ink); margin-bottom: 16px;
}
.section-title em { font-style: italic; color: var(--terra); }
.section-title-light { color: var(--bg); }
.muted { color: var(--ink-faint); }

/* ── PROJECTS ─── */
.projects-section { padding: 100px 0; }
.projects-list { margin-top: 52px; border-top: 1px solid var(--line); }
.project-card {
  display: grid; grid-template-columns: 48px 1fr auto;
  gap: 0 36px; padding: 48px 0;
  border-bottom: 1px solid var(--line);
  align-items: start; transition: background .2s;
}
.project-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 14px; font-weight: 400; color: var(--terra);
  letter-spacing: 0.06em; padding-top: 6px;
}
.project-body { display: flex; flex-direction: column; gap: 14px; }
.project-sub {
  font-size: 12px; font-weight: 500; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--ink-faint);
}
.project-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(26px, 3vw, 40px);
  font-weight: 400; letter-spacing: -0.2px; line-height: 1.1;
  color: var(--ink);
}
.project-desc { font-size: 15px; color: var(--ink-soft); line-height: 1.8; max-width: 620px; }
.project-stats { display: flex; gap: 36px; flex-wrap: wrap; }
.proj-stat-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 32px; font-weight: 400; letter-spacing: -1px; line-height: 1;
  color: var(--terra);
}
.proj-stat-label { font-size: 11px; color: var(--ink-faint); margin-top: 4px; line-height: 1.4; }
.project-arrow {
  display: flex; align-items: center; justify-content: center;
  width: 48px; height: 48px; border-radius: 50%;
  border: 1px solid var(--line); color: var(--ink);
  flex-shrink: 0; transition: all .2s; margin-top: 4px;
}
.project-arrow:hover { background: var(--terra); border-color: var(--terra); color: #fff; transform: rotate(45deg); }

/* ── ABOUT ─── */
.about-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 96px; align-items: center;
}
.about-photo-wrap { position: relative; }
.about-photo-img {
  width: 100%; aspect-ratio: 4/5;
  object-fit: cover; object-position: center top;
  border-radius: 120px 120px 0 0;/* pill top */
}
.about-chip {
  position: absolute; bottom: 28px; right: -24px;
  background: var(--terra); border-radius: 12px;
  padding: 16px 22px;
  box-shadow: 0 12px 36px rgba(196,103,74,.3);
}
.about-chip-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px; font-weight: 600; letter-spacing: 0.03em; line-height: 1;
  color: #fff;
}
.about-chip-label { font-size: 11px; color: rgba(255,255,255,.75); margin-top: 4px; }
.about-text { display: flex; flex-direction: column; gap: 22px; }
.about-lead {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(24px, 2.5vw, 34px); font-weight: 400; line-height: 1.3;
  color: var(--ink);
}
.about-lead em { font-style: italic; color: var(--terra); }
.about-body { font-size: 15px; color: var(--ink-soft); line-height: 1.85; }
.about-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px; }
.about-tag {
  font-size: 12px; font-weight: 400; padding: 6px 16px;
  border-radius: 100px; border: 1px solid var(--line-warm);
  color: var(--terra-dark); background: rgba(196,103,74,.06);
}

/* ── STATS ─── */
.stats-bar { padding: 0; background: var(--terra); }
.stats-grid { display: grid; grid-template-columns: repeat(4,1fr); }
.stat-item {
  padding: 52px 36px;
  border-right: 1px solid rgba(255,255,255,.2);
}
.stat-item:last-child { border-right: none; }
.stat-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(44px, 5vw, 68px); font-weight: 300;
  letter-spacing: -2px; line-height: 1; color: #fff;
}
.stat-desc { font-size: 13px; color: rgba(255,255,255,.7); margin-top: 10px; line-height: 1.55; }

/* ── REVIEWS ─── */
.reviews-intro { margin-bottom: 44px; }
.reviews-with-nav { display: flex; align-items: center; gap: 18px; }
.reviews-nav-btn {
  width: 50px; height: 50px; border-radius: 50%;
  border: 1px solid var(--line); background: var(--bg);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: all .2s; color: var(--ink); flex-shrink: 0;
}
.reviews-nav-btn:hover:not(:disabled) { background: var(--terra); border-color: var(--terra); color: #fff; }
.reviews-nav-btn:disabled { opacity: 0.2; cursor: default; }
.reviews-track-outer { overflow: hidden; flex: 1; cursor: grab; }
.reviews-track-outer:active { cursor: grabbing; }
.reviews-track {
  display: flex; gap: 20px; overflow-x: auto; scrollbar-width: none;
  -webkit-overflow-scrolling: touch; padding-bottom: 8px; touch-action: pan-x;
}
.reviews-track::-webkit-scrollbar { display: none; }
.review-card {
  flex: 0 0 300px; height: 390px; background: var(--bg);
  border: 1px solid var(--line); border-radius: 80px 80px 16px 16px;
  overflow: hidden; transition: box-shadow .3s, transform .3s; cursor: zoom-in;
}
.review-card:hover { box-shadow: 0 16px 48px rgba(30,20,16,.12); transform: translateY(-4px); }
.review-img-wrap { width: 100%; height: 100%; overflow: hidden; }
.review-img-wrap img {
  width: 100%; height: 100%; object-fit: cover; object-position: top;
  display: block; transition: transform .4s ease;
}
.review-card:hover .review-img-wrap img { transform: scale(1.04); }

/* ── BOOKS ─── */
.books-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; margin-top: 48px; }
.book-card {
  background: var(--bg); border: 1px solid var(--line);
  border-radius: 16px; overflow: hidden; transition: box-shadow .3s, transform .3s;
}
.book-card:hover { box-shadow: 0 12px 36px rgba(30,20,16,.09); transform: translateY(-3px); }
.book-img { width: 100%; aspect-ratio: 3/4; background: var(--bg-warm); }
.book-img img { width: 100%; height: 100%; object-fit: cover; }
.book-label { padding: 18px 18px; font-size: 13px; font-weight: 400; line-height: 1.5; color: var(--ink); }
.book-grade { font-size: 11px; color: var(--ink-faint); margin-top: 4px; }

/* ── VIDEO + SOCIALS ─── */
.video-socials-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
.video-card { border-radius: 16px; overflow: hidden; border: 1px solid var(--line-dark); }
.video-embed-wrap { position: relative; padding-bottom: 56.25%; height: 0; }
.video-embed-wrap iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; }
.video-caption { padding: 20px 24px; background: rgba(255,255,255,.05); border-top: 1px solid var(--line-dark); }
.video-caption strong {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px; font-weight: 400; color: var(--bg); display: block; margin-bottom: 4px;
}
.video-caption span { font-size: 12px; color: rgba(255,255,255,.4); }

.socials-col { display: flex; flex-direction: column; gap: 12px; }
.social-card {
  display: flex; align-items: center; gap: 18px;
  padding: 20px 24px; border-radius: 16px;
  border: 1px solid var(--line-dark); background: rgba(255,255,255,.04);
  color: var(--bg); transition: all .2s;
}
.social-card:hover { border-color: var(--terra-pale); background: rgba(196,103,74,.1); }
.social-card-icon {
  width: 44px; height: 44px; border-radius: 12px;
  background: rgba(255,255,255,.08);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  color: rgba(255,255,255,.6);
}
.social-card-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 17px; font-weight: 600; color: var(--bg);
}
.social-card-sub { font-size: 12px; color: rgba(255,255,255,.35); margin-top: 2px; }
.social-card-arrow { margin-left: auto; color: rgba(255,255,255,.25); flex-shrink: 0; transition: color .2s; }
.social-card:hover .social-card-arrow { color: var(--terra-pale); }

/* ── CONTACT ─── */
.contact-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: stretch; }
.contact-photo { border-radius: 120px 120px 16px 16px; overflow: hidden; position: relative; min-height: 400px; }
.contact-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }
.contact-form-side { padding-top: 8px; display: flex; flex-direction: column; }
.contact-lead {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(32px, 3.5vw, 48px); font-weight: 400; line-height: 1.1;
  margin-bottom: 12px; color: var(--ink);
}
.contact-lead em { font-style: italic; color: var(--terra); }
.contact-sub { font-size: 15px; color: var(--ink-soft); font-weight: 300; margin-bottom: 36px; line-height: 1.75; }
.form-field { display: flex; flex-direction: column; gap: 7px; margin-bottom: 16px; }
.form-field label {
  font-size: 11px; font-weight: 500; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--ink-faint);
}
.form-field input, .form-field select, .form-field textarea {
  font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 300;
  padding: 13px 16px; border: 1.5px solid var(--line); border-radius: 10px;
  outline: none; background: #fff; color: var(--ink); transition: border-color .2s; width: 100%;
}
.form-field input:focus, .form-field select:focus, .form-field textarea:focus { border-color: var(--terra); }
.form-field textarea { resize: vertical; min-height: 108px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.form-error-msg { font-size: 12px; color: #c0392b; display: none; margin-top: -10px; }
.field-err input, .field-err select { border-color: #c0392b; }
.field-err .form-error-msg { display: block; }
.btn-submit { width: 100%; padding: 15px; justify-content: center; font-size: 14px; border-radius: 100px; margin-top: 4px; }
.form-success {
  display: none; padding: 32px; background: rgba(196,103,74,.08);
  border-left: 3px solid var(--terra); border-radius: 12px;
}
.form-success h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px; font-weight: 600; margin-bottom: 8px; color: var(--ink);
}
.form-success p { color: var(--ink-soft); font-size: 15px; }

/* ── DIVIDER ─── */
.hr { height: 1px; background: var(--line); }

/* ── FOOTER ─── */
.footer { background: var(--bg-dark); color: rgba(255,255,255,.35); padding: 64px 0 44px; }
.footer-top {
  display: grid; grid-template-columns: 1fr 1fr 1fr;
  gap: 48px; padding-bottom: 48px;
  border-bottom: 1px solid rgba(255,255,255,.08); margin-bottom: 36px;
}
.footer-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 24px; font-weight: 600; color: var(--bg);
  display: block; margin-bottom: 10px;
}
.footer-tagline { font-size: 13px; color: rgba(255,255,255,.3); line-height: 1.7; }
.footer-col-title {
  font-size: 10px; font-weight: 500; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--terra-pale); margin-bottom: 16px;
}
.footer-col a { display: block; font-size: 14px; color: rgba(255,255,255,.4); margin-bottom: 10px; transition: color .2s; }
.footer-col a:hover { color: var(--terra-pale); }
.footer-bottom { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
.footer-copy { font-size: 12px; color: rgba(255,255,255,.2); }

/* ── MODAL ─── */
.img-modal {
  position: fixed; inset: 0; background: rgba(30,20,16,.88);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; pointer-events: none; transition: .25s ease; z-index: 9999;
}
.img-modal.active { opacity: 1; pointer-events: auto; }
.img-modal-content { position: relative; max-width: 92vw; max-height: 92vh; }
.img-modal-content img {
  max-width: 92vw; max-height: 92vh; object-fit: contain;
  border-radius: 16px; box-shadow: 0 20px 80px rgba(0,0,0,.6);
}
.img-modal-close {
  position: absolute; top: -16px; right: -16px; width: 40px; height: 40px;
  border-radius: 50%; background: var(--bg); border: none; cursor: pointer;
  font-size: 22px; display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 16px rgba(0,0,0,.25);
}

/* ── KEYFRAMES ─── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: none; }
}

/* ── RESPONSIVE ─── */
@media (max-width: 1024px) {
  .hero { grid-template-columns: 1fr; min-height: auto; }
  .hero-left { padding: 100px 48px 60px; order: 2; }
  .hero-left::after { display: none; }
  .hero-right { height: 65vw; max-height: 500px; order: 1; }
  .hero-photo-overlay { background: linear-gradient(to top, var(--bg) 0%, transparent 50%); }
  .about-grid { grid-template-columns: 1fr; gap: 56px; }
  .about-chip { right: 16px; }
  .stats-grid { grid-template-columns: repeat(2,1fr); }
  .stat-item:nth-child(2) { border-right: none; }
  .books-grid { grid-template-columns: repeat(2,1fr); }
  .contact-wrap { grid-template-columns: 1fr; gap: 56px; }
  .contact-photo { max-width: 380px; border-radius: 80px 80px 16px 16px; }
  .nav-links, .header-cta { display: none; }
  .burger { display: flex; }
  .footer-top { grid-template-columns: 1fr 1fr; }
  .video-socials-grid { grid-template-columns: 1fr; gap: 56px; }
  .reviews-nav-btn { display: none; }
  .reviews-with-nav { display: block; }
  .project-card { grid-template-columns: 1fr; gap: 16px; }
  .project-num { display: none; }
  .project-arrow { display: none; }
}
@media (max-width: 640px) {
  .container { padding: 0 24px; }
  .header-inner { padding: 0 24px; }
  .footer-top { grid-template-columns: 1fr; gap: 32px; }
  .footer-inner { padding: 0 24px; }
  .section { padding: 68px 0; }
  .hero-left { padding: 80px 24px 52px; }
  .hero-right { height: 72vw; }
