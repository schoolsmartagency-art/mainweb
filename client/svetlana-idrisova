<div class="policy-modal" id="reviewModal">
  <div class="policy-modal-overlay" onclick="closeReviewModal(event)"></div>
  <div class="policy-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="reviewModalTitle">
    <button type="button" class="policy-modal-close" onclick="closeReviewModal(event)" aria-label="Закрыть">&times;</button>
    <div class="review-modal-head">
      <img class="review-modal-avatar" id="reviewModalAvatar" src="" alt="">
      <div>
        <div class="review-modal-name" id="reviewModalTitle"></div>
        <div class="review-modal-meta" id="reviewModalMeta"></div>
      </div>
    </div>
    <p class="review-modal-text" id="reviewModalText"></p>
  </div>
</div>

<div class="diploma-lightbox" id="diplomaLightbox">
  <div class="diploma-lightbox-overlay" onclick="closeDiplomaLightbox(event)"></div>
  <button type="button" class="diploma-lightbox-close" onclick="closeDiplomaLightbox(event)" aria-label="Закрыть">&times;</button>
  <img id="diplomaLightboxImg" src="" alt="">
</div>

<script>
  (function loadMedia() {
    const heroPhoto = 'images/svetlana-idrisova/svetlana-hero.jpg';
    const aboutPhoto = 'images/svetlana-idrisova/svetlana-about.jpg';
    const fallbackPhoto = heroPhoto;

    function setImage(img, url, loading) {
      if (!img) return;
      img.loading = loading || 'lazy';
      img.onerror = () => {
        if (img.dataset.fallbackApplied) return;
        img.dataset.fallbackApplied = '1';
        img.src = fallbackPhoto;
      };
      img.src = url;
    }

    setImage(document.getElementById('hero-tutor-photo'), heroPhoto, 'eager');
    setImage(document.getElementById('hero-tutor-photo-mobile'), heroPhoto, 'eager');
    setImage(document.getElementById('about-tutor-photo'), aboutPhoto, 'lazy');
  })();

  // Nav background appears on scroll
  const navEl = document.querySelector('nav');
  function updateNavBg() {
    if (!navEl) return;
    navEl.classList.toggle('scrolled', window.scrollY > 40);
  }
  window.addEventListener('scroll', updateNavBg, { passive: true });
  updateNavBg();

  // Burger menu
  const burger = document.getElementById('burger');
  const mobileMenu = document.getElementById('mobileMenu');
  burger.addEventListener('click', () => {
    burger.classList.toggle('open');
    mobileMenu.classList.toggle('open');
  });
  function closeMenu() {
    burger.classList.remove('open');
    mobileMenu.classList.remove('open');
  }

  // Fade-in on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) e.target.classList.add('visible');
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

  // Sticky CTA after hero
  const stickyCta = document.getElementById('stickyCta');
  const heroSection = document.getElementById('home');
  const formSection = document.getElementById('form');

  function updateStickyCta() {
    if (!stickyCta || !heroSection) return;
    if (window.innerWidth > 768) {
      stickyCta.classList.remove('visible');
      document.body.classList.remove('has-sticky-cta');
      return;
    }
    const heroBottom = heroSection.offsetTop + heroSection.offsetHeight - 64;
    const formTop = formSection ? formSection.offsetTop : Infinity;
    const scrolledPastHero = window.scrollY > heroBottom;
    const beforeForm = window.scrollY + window.innerHeight * 0.85 < formTop;
    const show = scrolledPastHero && beforeForm;
    stickyCta.classList.toggle('visible', show);
    document.body.classList.toggle('has-sticky-cta', show);
  }

  window.addEventListener('scroll', updateStickyCta, { passive: true });
  window.addEventListener('resize', updateStickyCta);
  updateStickyCta();

  // Custom selects — dropdown stays within form width
  function closeAllSelects() {
    document.querySelectorAll('.select-wrap.open').forEach(w => {
      w.classList.remove('open');
      w.querySelector('.select-trigger')?.setAttribute('aria-expanded', 'false');
    });
  }

  function resetCustomSelect(select) {
    select.selectedIndex = 0;
    const wrap = select.closest('.select-wrap');
    const trigger = wrap?.querySelector('.select-trigger');
    const textSpan = trigger?.querySelector('.select-trigger-text');
    if (trigger && textSpan) {
      textSpan.textContent = select.options[0]?.text || '';
      trigger.classList.add('placeholder');
      trigger.classList.remove('error');
      trigger.setAttribute('aria-expanded', 'false');
    }
    wrap?.querySelectorAll('.select-option').forEach(o => o.classList.remove('selected'));
    wrap?.classList.remove('open');
  }

  document.querySelectorAll('.select-wrap').forEach(wrap => {
    const select = wrap.querySelector('select');
    if (!select || wrap.querySelector('.select-trigger')) return;

    const trigger = document.createElement('button');
    trigger.type = 'button';
    trigger.className = 'select-trigger placeholder';
    trigger.id = select.id + '-trigger';
    trigger.setAttribute('aria-labelledby', select.id + '-label');
    trigger.setAttribute('aria-haspopup', 'listbox');
    trigger.setAttribute('aria-expanded', 'false');

    const label = document.getElementById(select.id + '-label');
    if (label) label.setAttribute('for', trigger.id);

    const textSpan = document.createElement('span');
    textSpan.className = 'select-trigger-text';
    textSpan.textContent = select.options[select.selectedIndex]?.text || '';

    const chevron = document.createElement('span');
    chevron.className = 'select-chevron';
    chevron.setAttribute('aria-hidden', 'true');

    trigger.append(textSpan, chevron);

    const dropdown = document.createElement('div');
    dropdown.className = 'select-dropdown';
    dropdown.setAttribute('role', 'listbox');

    Array.from(select.options).forEach(opt => {
      if (opt.disabled || !opt.value) return;
      const item = document.createElement('button');
      item.type = 'button';
      item.className = 'select-option';
      item.textContent = opt.textContent;
      item.setAttribute('role', 'option');
      item.addEventListener('click', () => {
        select.value = opt.value;
        textSpan.textContent = opt.textContent;
        trigger.classList.remove('placeholder', 'error');
        dropdown.querySelectorAll('.select-option').forEach(o => o.classList.remove('selected'));
        item.classList.add('selected');
        wrap.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
      });
      dropdown.appendChild(item);
    });

    dropdown.addEventListener('click', e => e.stopPropagation());

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const wasOpen = wrap.classList.contains('open');
      closeAllSelects();
      if (!wasOpen) {
        wrap.classList.add('open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });

    wrap.append(trigger, dropdown);
  });

  document.addEventListener('click', closeAllSelects);

  // Policy modal
  function openPolicyModal(e) {
    if (e) e.preventDefault();
    document.getElementById('policyModal').classList.add('open');
    document.body.style.overflow = 'hidden';
    return false;
  }
  function closePolicyModal(e) {
    if (e) e.preventDefault();
    document.getElementById('policyModal').classList.remove('open');
    document.body.style.overflow = '';
    return false;
  }

  // Hero parallax on scroll
  (function() {
    const avatarFrame = document.querySelector('.avatar-frame');
    const heroBefore = document.querySelector('.hero');
    const heroContent = document.querySelector('.hero-content');
    function applyParallax() {
      const y = window.scrollY;
      if (y > window.innerHeight) return;
      if (avatarFrame) avatarFrame.style.transform = `translateY(${y * 0.07}px)`;
      if (heroContent) heroContent.style.transform = `translateY(${y * 0.03}px)`;
    }
    window.addEventListener('scroll', applyParallax, { passive: true });
  })();

  // Video reviews carousel
  (function () {
    const track = document.getElementById('videoCarouselTrack');
    const prev = document.getElementById('videoCarouselPrev');
    const next = document.getElementById('videoCarouselNext');
    if (!track || !prev || !next) return;
    const scrollByCard = () => {
      const card = track.querySelector('.video-review-wrap');
      return card ? card.offsetWidth + 20 : 240;
    };
    function updateArrowState() {
      const max = track.scrollWidth - track.clientWidth - 2;
      prev.disabled = track.scrollLeft <= 2;
      next.disabled = track.scrollLeft >= max;
    }
    prev.addEventListener('click', () => track.scrollBy({ left: -scrollByCard(), behavior: 'smooth' }));
    next.addEventListener('click', () => track.scrollBy({ left: scrollByCard(), behavior: 'smooth' }));
    track.addEventListener('scroll', updateArrowState, { passive: true });
    window.addEventListener('resize', updateArrowState);
    updateArrowState();
  })();

  // Video reviews — click anywhere on card to play
  document.querySelectorAll('.video-review-wrap').forEach(wrap => {
    const iframe = wrap.querySelector('iframe');
    if (!iframe) return;
    wrap.addEventListener('click', () => {
      if (wrap.classList.contains('playing')) return;
      document.querySelectorAll('.video-review-wrap.playing').forEach(w => w.classList.remove('playing'));
      if (!iframe.src.includes('autoplay=1')) {
        iframe.src = iframe.src + '&autoplay=1';
      }
      wrap.classList.add('playing');
    });
  });

  // Review modal (full text popup)
  document.getElementById('reviewsPhotoGrid')?.addEventListener('click', (e) => {
    const card = e.target.closest('.review-photo-item');
    if (!card) return;
    const avatar = card.querySelector('.review-avatar');
    const name = card.querySelector('.review-name');
    const meta = card.querySelector('.review-meta');
    const text = card.querySelector('.review-text');
    document.getElementById('reviewModalAvatar').src = avatar ? avatar.src : '';
    document.getElementById('reviewModalAvatar').alt = avatar ? avatar.alt : '';
    document.getElementById('reviewModalTitle').textContent = name ? name.textContent : '';
    document.getElementById('reviewModalMeta').textContent = meta ? meta.textContent : '';
    document.getElementById('reviewModalText').textContent = text ? text.textContent : '';
    document.getElementById('reviewModal').classList.add('open');
    document.body.style.overflow = 'hidden';
  });
  function closeReviewModal(e) {
    if (e) e.preventDefault();
    document.getElementById('reviewModal').classList.remove('open');
    document.body.style.overflow = '';
    return false;
  }

  // Diploma lightbox
  document.getElementById('diplomasGrid')?.addEventListener('click', (e) => {
    const card = e.target.closest('.review-screenshot-card');
    if (!card) return;
    const img = card.querySelector('img');
    if (!img) return;
    document.getElementById('diplomaLightboxImg').src = img.src;
    document.getElementById('diplomaLightboxImg').alt = img.alt;
    document.getElementById('diplomaLightbox').classList.add('open');
    document.body.style.overflow = 'hidden';
  });
  function closeDiplomaLightbox(e) {
    if (e) e.preventDefault();
    document.getElementById('diplomaLightbox').classList.remove('open');
    document.body.style.overflow = '';
    return false;
  }

  // Form submit
  function submitForm() {
    const fields = ['student_name','student_last','grade','format','parent_name','phone'];
    let valid = true;
    fields.forEach(id => {
      const el = document.getElementById(id);
      const trigger = el.closest('.select-wrap')?.querySelector('.select-trigger');
      if (!el.value.trim()) {
        if (trigger) trigger.classList.add('error');
        else el.style.borderColor = '#E24B4A';
        valid = false;
      } else {
        if (trigger) trigger.classList.remove('error');
        else el.style.borderColor = '';
      }
    });
    const consent = document.getElementById('consent');
    const consentRow = consent.closest('.consent-row');
    if (!consent.checked) {
      consentRow.classList.add('error');
      valid = false;
    } else {
      consentRow.classList.remove('error');
    }
    if (!valid) {
      alert('Пожалуйста, заполните все обязательные поля и подтвердите согласие на обработку данных.');
      return;
    }
    const toast = document.getElementById('toast');
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 4000);
    // Reset
    document.querySelectorAll('#form input, #form textarea').forEach(el => el.value = '');
    document.querySelectorAll('#form select').forEach(resetCustomSelect);
    consent.checked = false;
  }
// Toggle reviews — показать все / свернуть
const toggleBtn = document.getElementById('reviewsToggleBtn');
const photoGrid = document.getElementById('reviewsPhotoGrid');
const ctaWrapper = document.getElementById('reviewsCtaWrapper');
const photosWrapper = document.querySelector('.reviews-photos-wrapper');
let expanded = false;

if (toggleBtn && photoGrid && ctaWrapper) {
  toggleBtn.addEventListener('click', function() {
    expanded = !expanded;
    photoGrid.classList.toggle('expanded', expanded);
    toggleBtn.classList.toggle('is-expanded', expanded);
    if (photosWrapper) photosWrapper.classList.toggle('expanded', expanded);

    if (expanded) {
      ctaWrapper.classList.add('hidden');
    } else {
      ctaWrapper.classList.remove('hidden');
    }
  });
}
</script>
</body>
</html>
