<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Светлана Идрисова — репетитор по химии</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=PT+Serif:ital,wght@0,400;0,700;1,400&family=Geologica:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --teal-50: #F4EEFB;
    --teal-100: #DCC9F0;
    --teal-200: #C2A3E3;
    --teal-400: #9B7FC7;
    --teal-600: #7A5DA8;
    --teal-800: #4A3766;
    --mint: #F5D87A;
    --sage: #F0C419;
    --bg: #FFFCF4;
    --white: #ffffff;
    --text: #2B2330;
    --text-soft: #5C5266;
    --text-muted: #8A8094;
    --border: rgba(122,93,168,0.14);
    --font-display: 'PT Serif', Georgia, serif;
    --font-body: 'Geologica', sans-serif;
    --radius: 16px;
    --shadow: 0 4px 32px rgba(122,93,168,0.10);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--teal-50); }
  ::-webkit-scrollbar-thumb { background: var(--teal-200); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--teal-400); }
  * { scrollbar-width: thin; scrollbar-color: var(--teal-200) var(--teal-50); }

  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
    font-size: 16px;
    line-height: 1.7;
    overflow-x: hidden;
  }

  :root {
    --page-padding: 5vw;
  }

  /* NAV - transparent over hero, glass once scrolled */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: transparent;
    border-bottom: 1px solid transparent;
    box-shadow: none;
    padding: 0 var(--page-padding);
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease, backdrop-filter 0.3s ease;
  }
  nav.scrolled {
    background: rgba(255,252,244,0.72);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
    border-bottom: 1px solid rgba(122,93,168,0.10);
    box-shadow: 0 2px 20px rgba(122,93,168,0.06);
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--teal-600);
    text-decoration: none;
    font-weight: 700;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }
  .nav-links a {
    text-decoration: none;
    color: var(--text-soft);
    font-size: 0.9rem;
    font-weight: 400;
    transition: color 0.2s;
    letter-spacing: 0.02em;
  }
  .nav-links a:hover { color: var(--teal-400); }
  .nav-cta {
    background: var(--teal-400);
    color: white !important;
    padding: 0.45rem 1.2rem;
    border-radius: 40px;
    font-weight: 500 !important;
  }
  .nav-cta:hover { background: var(--teal-600) !important; color: white !important; }

  /* HERO ENTRANCE ANIMATIONS */
  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(28px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-fade-in {
    from { opacity: 0; transform: scale(0.97); }
    to { opacity: 1; transform: scale(1); }
  }
  @keyframes hero-slide-in {
    from { opacity: 0; transform: translateX(32px) translateY(-50%); }
    to { opacity: 1; transform: translateX(0) translateY(-50%); }
  }
  @keyframes hero-slide-in-left {
    from { opacity: 0; transform: translateX(-32px) translateY(-50%); }
    to { opacity: 1; transform: translateX(0) translateY(-50%); }
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 0.95fr 1.15fr;
    align-items: center;
    padding: 96px var(--page-padding) 64px;
    gap: 3rem;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -200px; right: -200px;
    width: 700px; height: 700px;
    background: radial-gradient(circle, var(--teal-50) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-tag {
    display: inline-block;
    background: var(--teal-50);
    color: var(--teal-600);
    border: 1px solid var(--teal-100);
    padding: 0.3rem 1rem;
    border-radius: 40px;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    animation: hero-fade-up 0.6s cubic-bezier(0.22,1,0.36,1) 0.05s both, tag-blink 2s ease-in-out 1.5s infinite;
  }
  @keyframes tag-blink {
    0%, 100% {
      color: var(--teal-600);
      border-color: var(--teal-100);
      background: var(--teal-50);
      box-shadow: none;
    }
    50% {
      color: var(--teal-400);
      border-color: var(--teal-400);
      background: rgba(155,127,199,0.14);
      box-shadow: 0 0 14px rgba(155,127,199,0.35);
    }
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    line-height: 1.15;
    margin-bottom: 1.5rem;
    color: var(--text);
    animation: hero-fade-up 0.7s cubic-bezier(0.22,1,0.36,1) 0.15s both;
  }
  .hero h1 em {
    color: var(--teal-400);
    font-style: italic;
  }
  .hero-desc {
    color: var(--text-soft);
    font-size: 1.05rem;
    margin-bottom: 2rem;
    animation: hero-fade-up 0.7s cubic-bezier(0.22,1,0.36,1) 0.28s both;
    max-width: 480px;
    font-weight: 300;
    line-height: 1.8;
  }
  .hero-btns {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    animation: hero-fade-up 0.7s cubic-bezier(0.22,1,0.36,1) 0.4s both;
  }
  .btn-primary {
    background: var(--teal-400);
    color: white;
    padding: 0.85rem 2rem;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    transition: background 0.2s, transform 0.15s;
    display: inline-block;
  }
  .btn-primary:hover { background: var(--teal-600); transform: translateY(-2px); }
  .btn-outline {
    border: 1.5px solid var(--teal-400);
    color: var(--teal-400);
    padding: 0.85rem 2rem;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    transition: all 0.2s;
    display: inline-block;
  }
  .btn-outline:hover { background: var(--teal-50); transform: translateY(-2px); }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }
  .avatar-frame {
    width: 460px; height: 540px;
    background: linear-gradient(145deg, var(--teal-50), var(--teal-100));
    border-radius: 40% 60% 60% 40% / 50% 40% 60% 50%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    overflow: hidden;
    position: relative;
    border: 2px solid var(--teal-100);
    animation: hero-fade-in 1s cubic-bezier(0.22,1,0.36,1) 0.2s both;
    will-change: transform;
  }
  .avatar-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    display: block;
  }
  .hero-photo-mobile {
    display: none;
    width: min(200px, 52vw);
    margin: 0 auto 1rem;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    border: 2px solid var(--teal-100);
    box-shadow: var(--shadow);
  }
  .hero-photo-mobile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    display: block;
  }
  .avatar-placeholder {
    width: 100%; height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 1rem;
  }
  .avatar-initials {
    width: 110px; height: 110px;
    background: var(--teal-400);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 2.4rem;
    color: white;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .avatar-name-tag {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--teal-800);
    font-weight: 700;
    text-align: center;
  }
  .avatar-sub {
    font-size: 0.85rem;
    color: var(--teal-600);
    text-align: center;
  }

  .stat-badges {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .stat-badges.left {
    left: -10px; top: 50%; transform: translateY(-50%);
    animation: hero-slide-in-left 0.7s cubic-bezier(0.22,1,0.36,1) 0.55s both;
  }
  .stat-badges.right {
    right: -10px; top: 40%; transform: translateY(-50%);
    animation: hero-slide-in 0.7s cubic-bezier(0.22,1,0.36,1) 0.65s both;
  }
  .stat-badge {
    background: white;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.7rem 1.1rem;
    box-shadow: var(--shadow);
    text-align: center;
    white-space: nowrap;
  }
  .stat-badge strong {
    display: block;
    font-family: var(--font-body);
    font-size: 1.6rem;
    color: var(--teal-400);
    font-weight: 600;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .stat-badge span {
    font-size: 0.72rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-stats-mobile { display: none; }

  /* SECTION */
  section {
    padding: 96px var(--page-padding);
  }
  #about, #diplomas { background: var(--teal-50); }
  #reviews { background: transparent; }
  #services { background: var(--white); }
  #form {
    background: linear-gradient(135deg, var(--teal-800) 0%, var(--teal-600) 60%, var(--teal-400) 100%);
  }
  .section-label {
    display: inline-block;
    background: var(--teal-50);
    color: var(--teal-600);
    border: 1px solid var(--teal-100);
    padding: 0.3rem 1rem;
    border-radius: 40px;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.2;
    margin-bottom: 1rem;
    color: var(--text);
  }
  .section-title em { color: var(--teal-400); font-style: italic; }
  .section-sub {
    color: var(--text-soft);
    max-width: 540px;
    font-weight: 300;
    font-size: 1.05rem;
  }
  .section-header { margin-bottom: 3.5rem; }
  .form-title em { display: inline; }

  /* ABOUT */
  .about-grid {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 4rem;
    align-items: center;
    max-width: 960px;
    margin: 0 auto;
  }
  .about-photo-wrap {
    border-radius: 24px;
    overflow: hidden;
    border: 2px solid var(--teal-100);
    box-shadow: var(--shadow);
    aspect-ratio: 4 / 5;
    background: var(--teal-50);
  }
  .about-photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
  }

  .about-text p {
    color: var(--text-soft);
    font-weight: 300;
    margin-bottom: 1.2rem;
    line-height: 1.85;
    font-size: 1.05rem;
  }
  .about-highlight {
    background: var(--teal-50);
    border-left: 3px solid var(--teal-400);
    padding: 1rem 1.5rem;
    border-radius: 0 12px 12px 0;
    margin: 1.5rem 0;
  }
  .about-highlight p {
    color: var(--teal-800) !important;
    font-weight: 400 !important;
    font-size: 1rem !important;
    margin: 0 !important;
    font-style: italic;
  }


  /* SERVICES */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .service-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem 1.75rem;
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
  }
  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
  }
  .service-card.featured {
    background: var(--teal-400);
    border-color: var(--teal-400);
    color: white;
  }
  .service-tag {
    display: inline-block;
    background: var(--teal-50);
    color: var(--teal-600);
    font-size: 0.75rem;
    padding: 0.2rem 0.7rem;
    border-radius: 40px;
    margin-bottom: 1rem;
    font-weight: 500;
  }
  .service-card h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    font-weight: 700;
  }
  .service-card.featured h3 { color: white; }
  .service-card p {
    font-size: 0.9rem;
    color: var(--text-soft);
    font-weight: 300;
    line-height: 1.6;
    margin-bottom: 1.25rem;
    flex: 1;
  }
  .service-card.featured p { color: rgba(255,255,255,0.85); }
  .price-line {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }
  .service-card.featured .price-line {
    border-top-color: rgba(255,255,255,0.22);
  }
  .price-amount {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .service-card.featured .price-amount { color: white; }
  .price-duration {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-weight: 400;
    white-space: nowrap;
  }
  .service-card.featured .price-duration { color: rgba(255,255,255,0.72); }
  .service-card.featured .service-tag {
    background: rgba(255,255,255,0.2);
    color: white;
  }

  /* FORMATS — staggered ladder layout */
  .formats-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 960px;
    margin: 0 auto;
  }
  .format-row {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    width: 100%;
  }
  .format-row:nth-child(even) { flex-direction: row-reverse; margin-left: 8%; }
  .format-row:nth-child(odd) { margin-right: 8%; }
  .format-num {
    font-family: var(--font-display);
    font-size: 2.4rem;
    color: var(--teal-200);
    font-weight: 700;
    line-height: 1;
    min-width: 64px;
  }
  .format-card {
    flex: 1;
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem 2rem;
    box-shadow: var(--shadow);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .format-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 36px rgba(122,93,168,0.16);
  }
  .format-row.featured .format-card {
    background: var(--teal-400);
    color: white;
    border-color: var(--teal-400);
  }
  .format-row.featured .format-num { color: var(--teal-200); }
  .format-card h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }
  .format-card > p {
    color: var(--text-soft);
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.1rem;
  }
  .format-row.featured .format-card > p { color: rgba(255,255,255,0.88); }
  .format-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .format-features li {
    font-size: 0.88rem;
    color: var(--text-soft);
    padding-left: 1.4rem;
    position: relative;
  }
  .format-features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--teal-400);
    font-weight: 700;
  }
  .format-row.featured .format-features li { color: rgba(255,255,255,0.92); }
  .format-row.featured .format-features li::before { color: white; }
  .format-card .price-line { border-top: 1px solid var(--border); }
  .format-row.featured .format-card .price-line { border-top-color: rgba(255,255,255,0.22); }
  .format-row.featured .format-card .price-amount { color: white; }
  .format-row.featured .format-card .price-duration { color: rgba(255,255,255,0.72); }

  /* HOW LESSONS WORK */
  .lessons-section {
    background: var(--teal-50);
    border-radius: 32px;
    max-width: 960px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }
  .lessons-section .section-header {
    margin-bottom: 2.5rem;
  }
  .lessons-video-wrap {
    width: 100%;
    margin: 0 auto;
    border-radius: 20px;
    overflow: hidden;
    border: 2px solid var(--teal-100);
    box-shadow: var(--shadow);
    background: var(--teal-800);
    aspect-ratio: 16 / 9;
  }
  .lessons-video-wrap video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    background: #000;
  }
  .lessons-note { display: none; }

  /* HOW IT WORKS */
  .steps-block {
    display: block;
    margin-top: 3rem;
  }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    position: relative;
  }
  .steps-grid::before {
    content: '';
    position: absolute;
    top: 56px;
    left: calc(12.5% + 1rem);
    right: calc(12.5% + 1rem);
    height: 1px;
    background: linear-gradient(to right, var(--teal-100), var(--teal-200), var(--teal-100));
  }
  .step-item { text-align: center; }
  .step-num {
    width: 112px;
    height: 112px;
    background: white;
    border: 2px solid var(--teal-200);
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-family: var(--font-body);
    font-size: 2.4rem;
    font-weight: 600;
    line-height: 1;
    color: var(--teal-400);
    margin: 0 auto 1.25rem;
    position: relative;
    z-index: 1;
    padding: 0;
    font-variant-numeric: tabular-nums;
    box-sizing: border-box;
  }
  .step-item h4 {
    font-weight: 500;
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }
  .step-item p {
    font-size: 0.85rem;
    color: var(--text-soft);
    font-weight: 300;
    line-height: 1.5;
  }

  /* DIPLOMAS — card catalog, all visible at once, click to zoom */
  #diplomas .section-header, #services .section-header {
    max-width: 960px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 3.5rem;
  }
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 960px;
    margin: 0 auto;
  }
  .review-screenshot-card {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 260px;
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    cursor: pointer;
  }
  .review-screenshot-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(122,93,168,0.14);
  }
  .review-screenshot-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .reviews-cta {
    text-align: center;
    margin-top: 2.5rem;
  }
  .reviews-cta a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .reviews-profi-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--teal-50);
    color: var(--teal-600);
    border: 1px solid var(--teal-100);
    padding: 0.35rem 0.9rem;
    border-radius: 40px;
    font-size: 0.8rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  /* FORM */
  #form .section-title,
  #form .section-sub { color: rgba(255,255,255,0.92); }
  #form .section-title em { color: var(--mint); font-style: italic; }
  #form .section-label { background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.85); }
  .form-section {
    background: white;
    border-radius: 24px;
    padding: 4rem var(--page-padding);
    border: none;
    box-shadow: 0 24px 80px rgba(0,0,0,0.25);
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
    box-sizing: border-box;
  }
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    min-width: 0;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }
  .form-group.full { grid-column: 1 / -1; }
  .form-group:has(.select-wrap) { grid-column: 1 / -1; }
  label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-soft);
    letter-spacing: 0.02em;
  }
  input, select, textarea {
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text);
    background: white;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    outline: none;
    width: 100%;
  }
  input:focus, select:focus, textarea:focus {
    border-color: var(--teal-400);
    background: white;
    box-shadow: 0 0 0 3px rgba(155,127,199,0.12);
  }
  .select-wrap {
    position: relative;
    width: 100%;
    max-width: 100%;
    min-width: 0;
  }
  .select-wrap select {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }
  .select-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text);
    background: white;
    cursor: pointer;
    text-align: left;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
  }
  .select-trigger.placeholder { color: var(--text-muted); }
  .select-trigger:focus {
    outline: none;
    border-color: var(--teal-400);
    background: white;
    box-shadow: 0 0 0 3px rgba(155,127,199,0.12);
  }
  .select-trigger.error { border-color: #E24B4A; }
  .select-trigger-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
    flex: 1;
  }
  .select-chevron {
    flex-shrink: 0;
    width: 10px;
    height: 10px;
    border-right: 2px solid var(--teal-400);
    border-bottom: 2px solid var(--teal-400);
    transform: rotate(45deg) translateY(-2px);
    transition: transform 0.2s;
  }
  .select-wrap.open .select-chevron {
    transform: rotate(-135deg) translateY(2px);
  }
  .select-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    width: 100%;
    box-sizing: border-box;
    background: white;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(122,93,168,0.12);
    z-index: 50;
    max-height: 240px;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  .select-wrap.open .select-dropdown { display: block; }
  .select-option {
    display: block;
    width: 100%;
    padding: 0.75rem 1rem;
    border: none;
    background: none;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text);
    text-align: left;
    cursor: pointer;
    transition: background 0.15s;
  }
  .select-option:hover,
  .select-option:focus {
    background: var(--teal-50);
    outline: none;
  }
  .select-option.selected {
    background: var(--teal-50);
    color: var(--teal-600);
    font-weight: 500;
  }
  textarea { resize: vertical; min-height: 100px; }
  .form-submit {
    margin-top: 2rem;
    text-align: center;
  }
  .form-submit button {
    background: var(--teal-400);
    color: white;
    border: none;
    padding: 1.05rem 2rem;
    border-radius: 40px;
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    width: 100%;
    max-width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    box-shadow: 0 4px 20px rgba(155,127,199,0.28);
  }
  .form-submit button:hover { background: var(--teal-600); transform: translateY(-2px); box-shadow: 0 6px 24px rgba(155,127,199,0.35); }
  .form-submit button:active { transform: translateY(0); }
  .form-note {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-align: center;
    margin-top: 1rem;
  }
  .consent-row {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: var(--text-soft);
  }
  .consent-row input[type="checkbox"] {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 2px;
    accent-color: var(--teal-400);
    cursor: pointer;
  }
  .consent-row label {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--text-soft);
    cursor: pointer;
  }
  .consent-row a {
    color: var(--teal-600);
    text-decoration: underline;
  }
  .consent-row.error label { color: #E24B4A; }

  /* POLICY MODAL */
  .policy-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.15s ease, visibility 0s linear 0.15s;
  }
  .policy-modal.open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: opacity 0.15s ease;
  }
  .policy-modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 20, 18, 0.55);
    backdrop-filter: blur(2px);
  }
  .policy-modal-dialog {
    position: relative;
    max-width: 640px;
    width: calc(100% - 2.4rem);
    max-height: calc(100vh - 4rem);
    margin: 2rem auto;
    background: #ffffff;
    border-radius: 16px;
    padding: 2rem 1.75rem 1.75rem;
    overflow-y: auto;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
    transform: scale(0.94) translateY(16px);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .policy-modal.open .policy-modal-dialog {
    transform: scale(1) translateY(0);
  }
  .policy-modal-dialog h3 {
    font-size: 1.2rem;
    margin: 0 0 0.4rem;
    padding-right: 2rem;
  }
  .policy-modal-meta {
    font-size: 0.8rem;
    color: var(--text-soft);
    margin: 0 0 1.2rem;
  }
  .policy-modal-body p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-soft);
    margin-bottom: 0.9rem;
  }
  .policy-modal-body p:last-child {
    margin-bottom: 0;
  }
  .policy-modal-body a {
    color: var(--teal-600);
    text-decoration: underline;
  }
  .policy-modal-close {
    position: absolute;
    top: 1.1rem;
    right: 1.1rem;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    font-size: 1.6rem;
    line-height: 1;
    color: var(--text-soft);
    cursor: pointer;
  }

  /* REVIEW MODAL */
  .review-modal-head {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: 1.2rem;
    padding-right: 1.5rem;
  }
  .review-modal-avatar {
    width: 56px;
    height: 56px;
    min-width: 56px;
    border-radius: 50%;
    object-fit: cover;
  }
  .review-modal-name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--text);
  }
  .review-modal-meta {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }
  .review-modal-text {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-soft);
  }

  /* DIPLOMA LIGHTBOX */
  .diploma-lightbox {
    display: flex;
    align-items: center;
    justify-content: center;
    position: fixed;
    inset: 0;
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s ease, visibility 0s linear 0.25s;
  }
  .diploma-lightbox.open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: opacity 0.25s ease;
  }
  .diploma-lightbox-overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 20, 18, 0.78);
  }
  .diploma-lightbox img {
    position: relative;
    max-width: min(90vw, 800px);
    max-height: 88vh;
    object-fit: contain;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    transform: scale(0.92);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .diploma-lightbox.open img {
    transform: scale(1);
  }
  .diploma-lightbox-close {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    color: white;
    font-size: 1.8rem;
    line-height: 1;
    cursor: pointer;
    z-index: 1;
  }

  /* FOOTER */
  footer {
    background: var(--text);
    color: rgba(255,255,255,0.7);
    padding: 3rem var(--page-padding);
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: white;
    font-weight: 700;
  }
  .footer-sub {
    font-size: 0.8rem;
    margin-top: 0.25rem;
    color: rgba(255,255,255,0.45);
  }
  .footer-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .footer-links a {
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--mint); }
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    margin-top: 2rem;
    padding-top: 1.5rem;
    font-size: 0.75rem;
    text-align: center;
    color: rgba(255,255,255,0.3);
  }

  /* TOAST */
  .toast {
    position: fixed;
    bottom: 2rem; right: 2rem;
    background: var(--teal-800);
    color: white;
    padding: 1rem 1.5rem;
    border-radius: 12px;
    font-size: 0.9rem;
    z-index: 999;
    transform: translateY(100px);
    opacity: 0;
    transition: all 0.3s;
    pointer-events: none;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .toast.show { transform: translateY(0); opacity: 1; }

  /* STICKY CTA - glass */
  .sticky-cta {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 95;
    padding: 0.75rem var(--page-padding) calc(0.75rem + env(safe-area-inset-bottom, 0px));
    background: rgba(255,252,244,0.82);
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    border-top: 1px solid rgba(122,93,168,0.12);
    box-shadow: 0 -4px 24px rgba(122,93,168,0.08);
    transform: translateY(110%);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .sticky-cta.visible {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
  .sticky-cta-btn {
    display: block;
    width: 100%;
    background: var(--teal-400);
    color: white;
    text-align: center;
    text-decoration: none;
    padding: 0.95rem 1rem;
    border-radius: 40px;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    box-shadow: 0 4px 20px rgba(155,127,199,0.28);
  }
  .sticky-cta-btn:hover { background: var(--teal-600); }

  /* BURGER MENU */
  .nav-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 6px;
    border: none;
    background: none;
    z-index: 200;
  }
  .nav-burger span {
    display: block;
    width: 24px; height: 2px;
    background: var(--teal-600);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }
  .nav-burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-burger.open span:nth-child(2) { opacity: 0; }
  .nav-burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 64px; left: 0; right: 0;
    background: rgba(255,252,244,0.92);
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    border-bottom: 1px solid rgba(122,93,168,0.10);
    box-shadow: 0 8px 24px rgba(122,93,168,0.08);
    padding: 1.5rem var(--page-padding) 2rem;
    z-index: 99;
    flex-direction: column;
    gap: 0;
  }
  .mobile-menu.open { display: flex; }
  .mobile-menu a {
    text-decoration: none;
    color: var(--text-soft);
    font-size: 1.1rem;
    font-weight: 400;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--border);
    transition: color 0.2s;
  }
  .mobile-menu a:hover { color: var(--teal-400); }

  /* TABLET 900–1100px */
  @media (max-width: 1100px) {
    .hero { gap: 2rem; padding: 96px 4vw 64px; }
    .avatar-frame { width: 340px; height: 400px; }
    .stat-badges.left { left: -10px; }
    .stat-badges.right { right: -10px; }
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
    .steps-grid::before { display: none; }
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* MOBILE < 768px */
  @media (max-width: 768px) {
    section { padding: 64px var(--page-padding); }

    /* NAV */
    .nav-links { display: none; }
    .nav-burger { display: flex; }
    /* mobile-menu uses glass too */

    body.has-sticky-cta { padding-bottom: calc(76px + env(safe-area-inset-bottom, 0px)); }

    /* HERO */
    .hero-content {
      display: flex;
      flex-direction: column;
    }
    .hero-tag { display: none; }
    .hero h1 { order: 2; margin-bottom: 1rem; }
    .hero-desc { order: 3; margin-bottom: 1rem; font-size: 0.92rem; line-height: 1.65; }
    .hero-photo-mobile { order: 4; margin-bottom: 1.25rem; }
    .hero-btns { order: 5; margin-bottom: 1.25rem; }
    .hero-stats-mobile { order: 6; }
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding: 80px var(--page-padding) 40px;
      gap: 0;
    }
    .hero::before { display: none; }
    .hero-photo-mobile { display: block; }
    .hero-visual { display: none; }
    .hero h1 { font-size: clamp(2rem, 8vw, 2.8rem); }
    .hero-desc { font-size: 0.98rem; max-width: 100%; }
    .hero-btns { flex-direction: column; }
    .btn-primary, .btn-outline { text-align: center; width: 100%; }

    /* mobile stats strip after hero text */
    .hero-stats-mobile {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
      margin-top: 0.5rem;
    }
    .hero-stat-m {
      background: white;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 0.9rem 1rem;
      text-align: center;
    }
    .hero-stat-m strong {
      display: block;
      font-family: var(--font-body);
      font-size: 1.6rem;
      color: var(--teal-400);
      font-weight: 600;
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }
    .hero-stat-m span {
      font-size: 0.72rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    /* ABOUT */
    .about-grid {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }
    .about-text { order: 1; }
    .about-photo-wrap { order: 2; max-width: 320px; margin: 0 auto; width: 100%; }

    /* SERVICES */
    .services-grid { grid-template-columns: 1fr; }

    /* FORMATS ladder — stack on mobile */
    .format-row,
    .format-row:nth-child(even),
    .format-row:nth-child(odd) {
      flex-direction: column;
      margin-left: 0;
      margin-right: 0;
      gap: 0.75rem;
    }
    .format-num { font-size: 1.8rem; }
    .format-card { padding: 1.5rem; width: 100%; }

    /* STEPS — vertical timeline on mobile */
    .steps-block { display: block; margin-top: 2.5rem; }
    .steps-grid {
      display: flex;
      flex-direction: column;
      gap: 0;
      max-width: 100%;
      margin: 0;
    }
    .steps-grid::before {
      display: block;
      left: 27px;
      right: auto;
      top: 28px;
      bottom: 28px;
      width: 2px;
      height: auto;
      transform: none;
      background: linear-gradient(to bottom, var(--teal-100), var(--teal-200), var(--teal-100));
    }
    .step-item {
      display: flex;
      gap: 1.25rem;
      align-items: flex-start;
      text-align: left;
      padding: 1rem 0;
    }
    .step-num {
      width: 56px;
      height: 56px;
      min-width: 56px;
      font-size: 1.35rem;
      margin: 0;
    }
    .step-content h4 { margin-bottom: 0.35rem; }

    /* DIPLOMAS */
    .reviews-grid { grid-template-columns: repeat(2, 1fr); gap: 0.85rem; }
    .review-screenshot-card { height: 160px; }

    .form-title em { display: block; }

    /* FORM */
    .form-section { padding: 2rem 1.25rem; border-radius: 16px; }
    .form-grid { grid-template-columns: 1fr; }
    .form-group.full { grid-column: 1; }
    .form-submit button {
      max-width: 100%;
      padding: 1.1rem 1.5rem;
      font-size: 1rem;
    }
    .select-trigger { font-size: 16px; }

    /* FOOTER */
    .footer-inner { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
    .footer-links { gap: 1rem; }

    /* HOW-IT-WORKS section */
    section.lessons-section {
      border-radius: 16px;
      max-width: none;
      margin-left: 1vw;
      margin-right: 1vw;
      width: auto;
    }
  }

  /* EXTRA SMALL < 400px */
  @media (max-width: 400px) {
    .hero h1 { font-size: 1.9rem; }
    .hero-stats-mobile { grid-template-columns: 1fr 1fr; }
    .sticky-cta-btn { font-size: 0.88rem; padding: 0.95rem 0.5rem; }
  }

  /* REVIEWS — колонки, картинки прижаты друг к другу сверху, с затемнением внизу */
/* REVIEWS — колонки, картинки прижаты друг к другу сверху, с затемнением внизу */
.reviews-photos-wrapper {
  position: relative;
  margin-bottom: 0;
}

.reviews-photos-wrapper:not(.expanded)::after {
  content: '';
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 160px;
  background: linear-gradient(to bottom, transparent, #FFFCF4 85%);
  pointer-events: none;
  z-index: 1;
}

.reviews-photos-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
  align-items: start;
  max-height: 620px;
  overflow: hidden;
  transition: max-height 0.5s ease;
}

.reviews-photos-grid.expanded {
  max-height: 6000px;
}

.review-col {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.review-photo-item {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow);
  transition: transform 0.2s, box-shadow 0.2s;
  padding: 1.25rem;
  height: 230px;
  display: flex;
  flex-direction: column;
  cursor: pointer;
  position: relative;
}

.review-photo-item::after {
  content: 'Читать полностью →';
  position: absolute;
  left: 1.25rem;
  right: 1.25rem;
  bottom: 0.6rem;
  font-size: 0.78rem;
  font-weight: 500;
  color: var(--teal-600);
  background: linear-gradient(to bottom, transparent, var(--bg) 55%);
  padding-top: 1.2rem;
  pointer-events: none;
}

.review-photo-item:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 32px rgba(122,93,168,0.14);
}

.review-card-head {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.85rem;
}

.review-avatar {
  width: 48px;
  height: 48px;
  min-width: 48px;
  border-radius: 50%;
  object-fit: cover;
  display: block;
