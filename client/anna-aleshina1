<script>
/* Year */
document.getElementById('yr').textContent = new Date().getFullYear();

/* Header scroll */
const header = document.getElementById('header');
window.addEventListener('scroll', () => {
  header.classList.toggle('scrolled', window.scrollY > 60);
}, { passive: true });

/* Burger */
const burger = document.getElementById('burger');
const mobileMenu = document.getElementById('mobileMenu');
burger.addEventListener('click', () => {
  burger.classList.toggle('open');
  mobileMenu.classList.toggle('open');
  document.body.style.overflow = mobileMenu.classList.contains('open') ? 'hidden' : '';
});
mobileMenu.querySelectorAll('a').forEach(a => {
  a.addEventListener('click', () => {
    burger.classList.remove('open');
    mobileMenu.classList.remove('open');
    document.body.style.overflow = '';
  });
});

/* Reveal */
const reveals = document.querySelectorAll('.reveal');
const revObs = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('visible'); revObs.unobserve(e.target); }
  });
}, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
reveals.forEach(el => revObs.observe(el));

/* Reviews drag */
const revTrack = document.getElementById('reviewsTrack');
const btnPrev = document.getElementById('revPrev');
const btnNext = document.getElementById('revNext');
let rDrag = false, rStartX = 0, rStartY = 0, rScrollLeft = 0, rMoved = false, rIsHoriz = null;

function updateNavBtns() {
  const atStart = revTrack.scrollLeft <= 2;
  const atEnd = revTrack.scrollLeft >= revTrack.scrollWidth - revTrack.clientWidth - 2;
  btnPrev.disabled = atStart;
  btnNext.disabled = atEnd;
}
revTrack.addEventListener('scroll', updateNavBtns, { passive: true });
updateNavBtns();

revTrack.addEventListener('mousedown', e => {
  rDrag = true; rMoved = false; rIsHoriz = null;
  rStartX = e.pageX; rScrollLeft = revTrack.scrollLeft;
  revTrack.style.userSelect = 'none';
});
document.addEventListener('mouseup', () => { 
  rDrag = false; 
  revTrack.style.userSelect = ''; 
  setTimeout(() => { rMoved = false; }, 0);
});

revTrack.addEventListener('touchstart', e => {
  rStartX = e.touches[0].clientX;
  rStartY = e.touches[0].clientY;
  rScrollLeft = revTrack.scrollLeft;
  rIsHoriz = null; rMoved = false;
}, { passive: true });

revTrack.addEventListener('touchmove', e => {
  const dx = e.touches[0].clientX - rStartX;
  const dy = e.touches[0].clientY - rStartY;
  if (rIsHoriz === null) rIsHoriz = Math.abs(dx) > Math.abs(dy);
  if (rIsHoriz) {
    e.preventDefault();
    revTrack.scrollLeft = rScrollLeft - dx;
    rMoved = true;
  }
}, { passive: false });

btnNext.addEventListener('click', () => {
  revTrack.scrollBy({ left: 320, behavior: 'smooth' });
});
btnPrev.addEventListener('click', () => {
  revTrack.scrollBy({ left: -320, behavior: 'smooth' });
});

/* Review modal */
const modal = document.getElementById('imgModal');
const modalImg = document.getElementById('imgModalImg');
document.querySelectorAll('.review-card').forEach(card => {
  card.addEventListener('click', () => {
    if (rMoved) { rMoved = false; return; }
    const img = card.querySelector('img');
    if (img) { modal.classList.add('active'); modalImg.src = img.src; }
  });
});
document.getElementById('imgModalClose').addEventListener('click', () => {
  modal.classList.remove('active'); modalImg.src = '';
});
modal.addEventListener('click', e => {
  if (e.target === modal) { modal.classList.remove('active'); modalImg.src = ''; }
});
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') { modal.classList.remove('active'); modalImg.src = ''; }
});

/* Form */
document.getElementById('contactForm').addEventListener('submit', e => {
  e.preventDefault();
  let ok = true;
  const name = document.getElementById('inp-name').value.trim();
  const phone = document.getElementById('inp-phone').value.trim();
  const fn = document.getElementById('f-name');
  const fp = document.getElementById('f-phone');
  fn.classList.toggle('field-err', !name);
  if (!name) ok = false;
  const phoneOk = phone && /^[+\d\s\-()\d]{7,}$/.test(phone);
  fp.classList.toggle('field-err', !phoneOk);
  if (!phoneOk) ok = false;
  if (ok) {
    document.getElementById('contactForm').style.display = 'none';
    document.getElementById('formSuccess').style.display = 'block';
  }
});
</script>
