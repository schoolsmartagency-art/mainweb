<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Анна Алёшина</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<style>
/* ── TOKENS ─────────────────────────── */
:root {
  --bg:          #EDEDE6;
  --bg-warm:     #F3F1EC;
  --bg-white:    #FFFFFF;
  --bg-dark:     #1A1F16;
  --ink:         #1C150E;
  --ink-head:    #2E211A;
  --ink-soft:    #5C5249;
  --ink-faint:   #A7A39E;
  --accent:      #7BC73D;
  --accent-dark: #6AA02F;
  --beige-soft:  #D2B1A3;
  --line:        #DDD9D2;
  --r:           14px;
  --r-lg:        24px;
  --r-card:      24px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  font-family: 'Inter', sans-serif;
  font-size: 16px;
  line-height: 1.65;
  color: var(--ink);
  background: var(--bg);
  overflow-x: hidden;
}

img { display: block; max-width: 100%; }
a { color: inherit; text-decoration: none; }
button { font-family: inherit; cursor: pointer; border: none; background: none; }

/* ── UTIL ─── */
.container { max-width: 1180px; margin: 0 auto; padding: 0 36px; }

.eyebrow { display: none; }
.eyebrow-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
}

.section-title {
  font-family: 'Manrope', sans-serif;
  font-size: clamp(32px, 4.5vw, 52px);
  font-weight: 800;
  line-height: 1.05;
  letter-spacing: -1px;
  color: var(--ink-head);
  margin-bottom: 20px;
}
.section { padding: 96px 0; }
.section-dark { background: var(--bg-dark); }
.section-warm { background: var(--bg-warm); }
.muted { color: var(--ink-soft); }

/* ── REVEAL ─── */
.reveal {
  opacity: 0;
  transform: translateY(32px);
  transition: opacity 0.7s cubic-bezier(.22,.68,0,1.05), transform 0.7s cubic-bezier(.22,.68,0,1.05);
}
.reveal.left  { transform: translateX(-32px); }
.reveal.right { transform: translateX(32px); }
.reveal.up    { transform: translateY(32px); }
.reveal.scale { transform: scale(0.94) translateY(16px); }
.reveal.visible { opacity: 1 !important; transform: translate(0,0) scale(1) !important; }
.d1 { transition-delay: .10s; }
.d2 { transition-delay: .20s; }
.d3 { transition-delay: .30s; }
.d4 { transition-delay: .40s; }

/* ── HEADER ─── */
.header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 200;
  padding: 0;
  opacity: 0;
  transform: translateY(-100%);
  transition: background .3s, box-shadow .3s, opacity .4s ease, transform .4s ease;
  pointer-events: none;
}
.header.scrolled {
  background: rgba(237,237,230,0.92);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  box-shadow: 0 2px 20px rgba(28,21,14,.06);
  opacity: 1;
  transform: translateY(0);
  pointer-events: all;
}
.header-inner {
  max-width: 1180px;
  margin: 0 auto;
  padding: 0 36px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.header-logo {
  font-family: 'Manrope', sans-serif;
  font-size: 16px;
  font-weight: 800;
  color: var(--ink);
  opacity: 0;
  transition: opacity .3s;
  letter-spacing: -.3px;
}
.header.scrolled .header-logo { opacity: 1; }
.nav-links { display: flex; gap: 28px; }
.nav-links a {
  font-size: 14px;
  font-weight: 500;
  color: var(--ink);
  opacity: 0.55;
  transition: opacity .2s;
}
.nav-links a:hover { opacity: 1; }
.header-cta {
  font-size: 13px;
  font-weight: 600;
  padding: 9px 20px;
  border-radius: 100px;
  background: var(--accent);
  color: var(--ink-head);
  transition: background .2s, transform .15s;
}
.header-cta:hover { background: var(--accent-dark); color: #fff; transform: translateY(-1px); }

.burger { display: none; flex-direction: column; gap: 5px; padding: 6px; }
.burger span { display: block; width: 22px; height: 1.5px; background: var(--ink); transition: all .3s; }
.burger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.burger.open span:nth-child(2) { opacity: 0; }
.burger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

.mobile-menu {
  position: fixed; inset: 0; z-index: 190;
  background: var(--bg);
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 32px;
  opacity: 0; pointer-events: none; transition: opacity .3s;
}
.mobile-menu.open { opacity: 1; pointer-events: all; }
.mobile-menu a { font-family: 'Manrope', sans-serif; font-size: 30px; font-weight: 800; color: var(--ink); letter-spacing: -1px; }

/* ── HERO ─── */
.hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  overflow: hidden;
}
.hero-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 100px 48px 80px max(36px, calc((100vw - 1180px)/2 + 36px));
  position: relative;
  z-index: 2;
}
.hero-eyebrow {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--ink-soft);
  margin-bottom: 24px;
  opacity: 0;
  animation: fadeUp .8s .3s forwards;
}
.hero-name {
  font-family: 'Manrope', sans-serif;
  font-size: clamp(56px, 7.5vw, 96px);
  font-weight: 800;
  line-height: .96;
  letter-spacing: -2px;
  color: var(--ink-head);
  margin-bottom: 30px;
  opacity: 0;
  animation: fadeUp .8s .5s forwards;
}
.hero-name .accent-line {
  position: relative;
  display: inline-block;
}
.hero-name .accent-line::after {
  content: '';
  position: absolute;
  bottom: -4px; left: 0;
  height: 4px;
  width: 0;
  background: var(--accent);
  border-radius: 2px;
  animation: lineGrow .7s 1.3s forwards;
}
.hero-desc {
  font-size: 17px;
  font-weight: 400;
  color: var(--ink-soft);
  max-width: 440px;
  line-height: 1.75;
  margin-bottom: 40px;
  opacity: 0;
  animation: fadeUp .8s .7s forwards;
}
.hero-actions {
  display: flex; gap: 12px; flex-wrap: wrap;
  opacity: 0; animation: fadeUp .8s .9s forwards;
}
.btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 13px 26px;
  border-radius: 100px;
  font-size: 14px; font-weight: 600;
  transition: all .2s;
}
.btn-green { background: var(--accent); color: var(--ink-head); }
.btn-green:hover { background: var(--accent-dark); color: var(--ink-head); }
.btn-ghost { border: 1.5px solid rgba(28,21,14,.25); color: var(--ink); background: rgba(255,255,255,.6); }
.btn-ghost:hover { border-color: var(--ink); background: rgba(255,255,255,.9); }

.hero-right {
  position: relative;
  overflow: hidden;
}
.hero-photo-main {
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center top;
}
.hero-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 40%;
  background: linear-gradient(to top, rgba(237,237,230,.3), transparent);
  pointer-events: none;
}
.hero-badges {
  position: absolute;
  top: 40px; right: 40px;
  display: flex; flex-direction: column; gap: 12px;
  opacity: 0; animation: fadeUp .8s 1.1s forwards;
}
.hero-badge {
  background: rgba(237,237,230,.92);
  backdrop-filter: blur(8px);
  border: 1px solid var(--line);
  border-radius: var(--r);
  padding: 12px 18px;
  text-align: right;
}
.hero-badge-num {
  font-family: 'Manrope', sans-serif;
  font-size: 24px; font-weight: 800;
  letter-spacing: -1px; line-height: 1;
  color: var(--ink-head);
}
.hero-badge-label { font-size: 11px; color: var(--ink-soft); margin-top: 2px; }

/* ── PROJECTS ─── */
.projects-section { padding: 96px 0; background: var(--bg-white); }
.projects-grid { display: grid; grid-template-columns: 1fr; gap: 0; margin-top: 48px; }

.project-card {
  background: transparent;
  border: none;
  border-radius: 0;
  padding: 44px 0;
  display: flex; flex-direction: column; gap: 20px;
  position: relative;
}
.project-card:not(:last-child) { border-bottom: 1px solid var(--line); }
.project-card:hover { background: transparent; }

.project-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20px;
}

.project-title {
  font-family: 'Manrope', sans-serif;
  font-size: clamp(22px, 2.8vw, 34px);
  font-weight: 800;
  letter-spacing: -.5px;
  line-height: 1.1;
  color: var(--ink-head);
}
.project-sub {
  font-size: 14px; font-weight: 500;
  color: var(--accent-dark);
  margin-top: 6px;
}
.project-desc {
  font-size: 15px; font-weight: 400;
  color: var(--ink-soft);
  line-height: 1.75;
  max-width: 800px;
}
.project-stats {
  display: grid; grid-template-columns: repeat(3, auto);
  gap: 32px;
  width: fit-content;
}
.proj-stat-num {
  font-family: 'Manrope', sans-serif;
  font-size: 22px; font-weight: 800;
  letter-spacing: -1px; line-height: 1;
  color: var(--ink-head);
}
.proj-stat-label { font-size: 11px; color: var(--ink-faint); margin-top: 3px; line-height: 1.3; }

.project-link-arrow {
  display: inline-flex; align-items: center; justify-content: center;
  width: 44px; height: 44px;
  border-radius: 50%;
  border: 1.5px solid var(--line);
  color: var(--ink);
  flex-shrink: 0;
  transition: all .2s;
  margin-top: 2px;
}
.project-link-arrow:hover {
  background: var(--ink);
  border-color: var(--ink);
  color: #fff;
  transform: translate(2px, -2px);
}

/* ── ABOUT ─── */
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.about-photo { position: relative; }
.about-photo-img {
  width: 100%; aspect-ratio: 4/5;
  object-fit: cover; object-position: center top;
  border-radius: var(--r-lg);
}
.about-chip {
  position: absolute;
  top: 32px; right: -20px;
  background: #fff;
  border: 1px solid var(--line);
  border-radius: var(--r);
  padding: 14px 20px;
  box-shadow: 0 8px 24px rgba(0,0,0,.08);
}
.about-chip-num {
  font-family: 'Manrope', sans-serif;
  font-size: 28px; font-weight: 800; letter-spacing: -1px; line-height: 1;
  color: var(--accent-dark);
}
.about-chip-label { font-size: 11px; color: var(--ink-soft); margin-top: 3px; }
.about-text { display: flex; flex-direction: column; gap: 20px; }
.about-lead {
  font-family: 'Manrope', sans-serif;
  font-size: clamp(22px, 2.5vw, 30px);
  font-weight: 700; line-height: 1.25; letter-spacing: -.5px;
  color: var(--ink-head);
}
.about-body { font-size: 16px; font-weight: 400; color: var(--ink-soft); line-height: 1.8; }
.about-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; }
.about-tag {
  font-size: 13px; padding: 7px 16px;
  border-radius: 100px;
  border: 1.5px solid var(--line);
  color: var(--ink);
}

/* ── REVIEWS ─── */
.reviews-intro {
  margin-bottom: 40px;
}
.reviews-with-nav {
  display: flex;
  align-items: center;
  gap: 16px;
}
.reviews-nav-btn {
  width: 48px; height: 48px; border-radius: 50%;
  border: 1.5px solid var(--line);
  background: var(--bg-white);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: all .2s;
  color: var(--ink);
  flex-shrink: 0;
}
.reviews-nav-btn:hover:not(:disabled) { border-color: var(--ink); background: var(--ink); color: #fff; }
.reviews-nav-btn:disabled { opacity: 0.25; cursor: default; }

.reviews-track-outer { overflow: hidden; flex: 1; cursor: grab; }
.reviews-track-outer:active { cursor: grabbing; }
.reviews-track {
  display: flex; gap: 20px;
  overflow-x: auto;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 8px;
    touch-action: pan-x;

}
.reviews-track::-webkit-scrollbar { display: none; }

.review-card {
  flex: 0 0 300px;
  background: var(--bg-white);
  border: 1px solid var(--line);
  border-radius: var(--r-card);
  overflow: hidden;
  box-shadow: 0 4px 16px rgba(0,0,0,.04);
  transition: box-shadow .3s, transform .3s;
  cursor: zoom-in;
  height: 380px;
}
.review-card:hover { box-shadow: 0 12px 36px rgba(0,0,0,.09); transform: translateY(-2px); }

.review-img-wrap {
  width: 100%;
  height: 100%;
  overflow: hidden;
  border-radius: var(--r-card);
}
.review-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top;
  display: block;
  cursor: zoom-in;
  transition: transform .35s cubic-bezier(.22,.68,0,1.2);
}
.review-card:hover .review-img-wrap img { transform: scale(1.03); }

/* ── STATS BAR ─── */
.stats-bar {
  padding: 64px 0;
  background: var(--bg-white);
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
}
.stat-item {
  padding: 32px 28px;
  border-right: 1px solid var(--line);
}
.stat-item:last-child { border-right: none; }
.stat-num {
  font-family: 'Manrope', sans-serif;
  font-size: clamp(36px, 4vw, 52px);
  font-weight: 800; letter-spacing: -2px; line-height: 1;
  color: var(--ink-head);
}
.stat-num .stat-unit { font-size: .5em; font-weight: 600; letter-spacing: 0; vertical-align: super; }
.stat-desc { font-size: 14px; color: var(--ink-soft); margin-top: 8px; line-height: 1.5; }

/* ── ADMISSIONS ─── */
.admissions-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-top: 48px;
}
.admission-card {
  background: var(--bg-white);
  border: 1px solid var(--line);
  border-radius: var(--r-card);
  padding: 28px 24px;
  display: flex; flex-direction: column; gap: 10px;
  box-shadow: 0 4px 16px rgba(0,0,0,.04);
  transition: box-shadow .3s;
}
.admission-card:hover { box-shadow: 0 10px 32px rgba(0,0,0,.08); }
.admission-num {
  font-family: 'Manrope', sans-serif;
  font-size: 38px; font-weight: 800; letter-spacing: -1px; line-height: 1;
  color: var(--accent-dark);
}
.admission-label { font-size: 14px; font-weight: 500; color: var(--ink); line-height: 1.4; }
.admission-sub { font-size: 12px; color: var(--ink-faint); }

/* ── BOOKS ─── */
.books-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  margin-top: 40px;
}
.book-card {
  background: var(--bg-white);
  border: 1px solid var(--line);
  border-radius: var(--r-card);
  overflow: hidden;
  box-shadow: 0 4px 16px rgba(0,0,0,.04);
}
.book-img {
  width: 100%; aspect-ratio: 3/4;
  background: var(--bg-warm);
  display: flex; align-items: center; justify-content: center;
  color: var(--ink-faint);
  font-size: 13px; text-align: center;
}
.book-img img { width: 100%; height: 100%; object-fit: cover; }
.book-img-placeholder { display: flex; flex-direction: column; align-items: center; gap: 12px; padding: 20px; }
.book-label {
  padding: 16px 18px;
  font-size: 13px; font-weight: 500; line-height: 1.45;
  color: var(--ink);
}
.book-grade { font-size: 11px; color: var(--ink-faint); margin-top: 4px; }

/* ── VIDEO ─── */
.videos-grid {
  max-width: 100%;
}
.video-card { border-radius: var(--r-card); overflow: hidden; background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.1); }
.video-embed-wrap { position: relative; padding-bottom: 56.25%; height: 0; }
.video-embed-wrap iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; }
.video-caption { padding: 18px 22px; background: rgba(255,255,255,.06); border-top: 1px solid rgba(255,255,255,.1); }
.video-caption strong { font-family: 'Manrope', sans-serif; font-size: 15px; font-weight: 700; color: rgba(255,255,255,.9); display: block; margin-bottom: 4px; }
.video-caption span { font-size: 13px; color: rgba(255,255,255,.45); }

/* ── SOCIALS ─── */
.socials-row { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 40px; }
.social-btn {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 12px 22px;
  border-radius: 100px;
  border: 1.5px solid rgba(255,255,255,.15);
  color: rgba(255,255,255,.75);
  font-size: 14px; font-weight: 500;
  transition: all .2s;
  background: rgba(255,255,255,.05);
}
.social-btn:hover { border-color: var(--accent); color: var(--accent); background: rgba(123,199,61,.08); }

.socials-col { display: flex; flex-direction: column; gap: 12px; }
.social-card {
  display: flex; align-items: center; gap: 16px;
  padding: 20px 24px;
  border-radius: var(--r);
  border: 1px solid rgba(255,255,255,.1);
  background: rgba(255,255,255,.04);
  color: rgba(255,255,255,.85);
  transition: all .2s;
  text-decoration: none;
}
.social-card:hover { border-color: var(--accent); background: rgba(123,199,61,.07); }
.social-card-icon {
  width: 44px; height: 44px;
  border-radius: 12px;
  background: rgba(255,255,255,.08);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  color: rgba(255,255,255,.7);
}
.social-card-name { font-family: 'Manrope', sans-serif; font-size: 15px; font-weight: 700; color: #fff; }
.social-card-sub { font-size: 12px; color: rgba(255,255,255,.4); margin-top: 2px; }
.social-card-arrow { margin-left: auto; color: rgba(255,255,255,.3); flex-shrink: 0; transition: color .2s; }
.social-card:hover .social-card-arrow { color: var(--accent); }

/* ── CONTACT ─── */
.contact-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
.contact-photo { border-radius: var(--r-lg); overflow: hidden; }
.contact-photo img { width: 100%; aspect-ratio: 3/4; object-fit: cover; object-position: center top; }
.contact-lead {
  font-family: 'Manrope', sans-serif;
  font-size: clamp(26px, 3vw, 38px);
  font-weight: 800; letter-spacing: -1px; line-height: 1.15;
  margin-bottom: 12px; color: var(--ink-head);
}
.contact-sub { font-size: 16px; color: var(--ink-soft); font-weight: 400; margin-bottom: 36px; line-height: 1.6; }

.form-field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
.form-field label { font-size: 13px; font-weight: 600; color: var(--ink-soft); }
.form-field input,
.form-field select,
.form-field textarea {
  font-family: 'Inter', sans-serif;
  font-size: 15px; font-weight: 400;
  padding: 13px 16px;
  border: 1.5px solid var(--line);
  border-radius: var(--r);
  outline: none;
  background: var(--bg-white);
  color: var(--ink);
  transition: border-color .2s;
  width: 100%;
}
.form-field input:focus,
.form-field select:focus,
.form-field textarea:focus { border-color: var(--accent); }
.form-field textarea { resize: vertical; min-height: 100px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.form-error-msg { font-size: 12px; color: #c0392b; display: none; margin-top: -10px; }
.field-err input, .field-err select { border-color: #c0392b; }
.field-err .form-error-msg { display: block; }
.form-success {
  display: none; padding: 32px;
  background: #f0f8e8; border: 1px solid #b8ddb0;
  border-radius: var(--r-lg); text-align: center;
}
.form-success h3 { font-family: 'Manrope', sans-serif; font-size: 20px; font-weight: 800; margin-bottom: 8px; color: var(--ink-head); }
.form-success p { color: var(--ink-soft); }

/* ── DIVIDER ─── */
.divider { height: 1px; background: var(--line); margin: 0 36px; }

/* ── FOOTER ─── */
.footer { background: var(--bg-dark); color: rgba(255,255,255,.4); padding: 56px 0 40px; }
.footer-inner {
  max-width: 1180px; margin: 0 auto; padding: 0 36px;
}
.footer-top {
  display: grid; grid-template-columns: 1fr 1fr 1fr;
  gap: 40px; padding-bottom: 40px;
  border-bottom: 1px solid rgba(255,255,255,.08);
  margin-bottom: 32px;
}
