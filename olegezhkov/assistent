<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>База знаний — Олег Ежков</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #ffffff;
    --bg-hover: #f7f7f5;
    --bg-tag: #f1f1ef;
    --border: #e8e8e5;
    --text-primary: #1a1a1a;
    --text-secondary: #787774;
    --text-tertiary: #9b9b97;
    --accent: #2f6fe8;
    --accent-soft: #e8f0fd;
    --green: #0f7b6c;
    --green-soft: #e3f5f2;
    --orange: #c35f00;
    --orange-soft: #fdf3e8;
    --purple: #6940a5;
    --purple-soft: #f0ebfa;
    --sidebar-w: 240px;
  }

  html { font-size: 15px; }
  body {
    font-family: 'Inter', -apple-system, sans-serif;
    background: var(--bg);
    color: var(--text-primary);
    display: flex;
    min-height: 100vh;
  }

  /* Sidebar */
  .sidebar {
    width: var(--sidebar-w);
    min-height: 100vh;
    background: #fbfaf9;
    border-right: 1px solid var(--border);
    padding: 12px 8px;
    position: fixed;
    top: 0; left: 0;
    overflow-y: auto;
    z-index: 10;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 8px 16px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 8px;
  }

  .avatar {
    width: 28px; height: 28px;
    border-radius: 6px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    display: flex; align-items: center; justify-content: center;
    color: white; font-size: 12px; font-weight: 600;
    flex-shrink: 0;
  }

  .workspace-name {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 5px 8px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 13.5px;
    color: var(--text-secondary);
    text-decoration: none;
    transition: background 0.1s;
  }
  .nav-item:hover { background: var(--bg-hover); color: var(--text-primary); }
  .nav-item.active { background: var(--bg-tag); color: var(--text-primary); }

  .nav-icon { font-size: 14px; width: 18px; text-align: center; }

  .nav-section {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-tertiary);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 14px 8px 4px;
  }

  /* Main content */
  .main {
    margin-left: var(--sidebar-w);
    flex: 1;
    max-width: 860px;
    padding: 60px 80px 120px;
  }

  /* Page header */
  .page-emoji { font-size: 52px; margin-bottom: 12px; line-height: 1; }

  .page-title {
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 6px;
  }

  .page-subtitle {
    font-size: 14px;
    color: var(--text-tertiary);
    margin-bottom: 32px;
  }

  /* Properties block */
  .properties {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 4px 0;
    margin-bottom: 36px;
  }

  .prop-row {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 5px 0;
    font-size: 13.5px;
    min-height: 32px;
  }

  .prop-key {
    width: 160px;
    flex-shrink: 0;
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
  }

  .prop-value {
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 500;
    background: var(--bg-tag);
    color: var(--text-secondary);
  }

  .tag.blue { background: var(--accent-soft); color: var(--accent); }
  .tag.green { background: var(--green-soft); color: var(--green); }
  .tag.orange { background: var(--orange-soft); color: var(--orange); }
  .tag.purple { background: var(--purple-soft); color: var(--purple); }

  /* Divider */
  .divider {
    height: 1px;
    background: var(--border);
    margin: 36px 0;
  }

  /* Headings */
  h2 {
    font-size: 20px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 16px;
    margin-top: 36px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  h2:first-child { margin-top: 0; }

  h3 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 10px;
    margin-top: 24px;
  }

  p {
    font-size: 14.5px;
    line-height: 1.7;
    color: var(--text-primary);
    margin-bottom: 10px;
  }

  /* Callout */
  .callout {
    background: var(--bg-tag);
    border-radius: 6px;
    padding: 12px 14px;
    display: flex;
    gap: 10px;
    margin-bottom: 16px;
    font-size: 14px;
    line-height: 1.6;
  }
  .callout-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }

  /* Cards for projects */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 12px;
    margin-bottom: 20px;
  }

  .card {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px;
    background: var(--bg);
    transition: box-shadow 0.15s, border-color 0.15s;
    cursor: default;
  }
  .card:hover { box-shadow: 0 2px 12px rgba(0,0,0,0.07); border-color: #d8d8d4; }

  .card-title {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .card-body {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .card-role {
    margin-top: 10px;
    font-size: 12px;
    font-weight: 500;
    color: var(--accent);
    background: var(--accent-soft);
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
  }

  /* Toggle-style block */
  .toggle-block {
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 8px;
  }

  .toggle-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    background: var(--bg);
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    user-select: none;
    transition: background 0.1s;
  }
  .toggle-header:hover { background: var(--bg-hover); }

  .toggle-arrow {
    font-size: 10px;
    color: var(--text-tertiary);
    transition: transform 0.2s;
    margin-left: auto;
  }
  .toggle-block.open .toggle-arrow { transform: rotate(90deg); }

  .toggle-content {
    display: none;
    padding: 4px 14px 14px 36px;
    background: var(--bg);
    border-top: 1px solid var(--border);
  }
  .toggle-block.open .toggle-content { display: block; }

  /* Task list */
  .task-list { list-style: none; }
  .task-list li {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    padding: 4px 0;
    font-size: 14px;
    color: var(--text-primary);
    line-height: 1.5;
  }
  .task-list li::before {
    content: '';
    width: 14px; height: 14px;
    border: 1.5px solid var(--border);
    border-radius: 3px;
    flex-shrink: 0;
    margin-top: 3px;
    background: var(--bg);
  }

  /* Bullet list */
  .bullet-list { list-style: none; }
  .bullet-list li {
    display: flex;
    gap: 8px;
    padding: 3px 0;
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-primary);
  }
  .bullet-list li::before {
    content: '•';
    color: var(--text-tertiary);
    font-size: 16px;
    line-height: 1.4;
    flex-shrink: 0;
  }

  /* Quote */
  .quote {
    border-left: 3px solid var(--border);
    padding: 4px 0 4px 16px;
    color: var(--text-secondary);
    font-size: 14px;
    font-style: italic;
    margin: 12px 0;
    line-height: 1.6;
  }

  /* Skills pills */
  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 8px;
  }

  .skill-pill {
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 12.5px;
    border: 1px solid var(--border);
    color: var(--text-secondary);
    background: var(--bg);
  }

  /* Inline code */
  code {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 12.5px;
    background: var(--bg-tag);
    padding: 2px 5px;
    border-radius: 4px;
    color: var(--text-primary);
  }

  /* Column layout */
  .columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 16px;
  }

  /* Photo gallery */
  .photo-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-bottom: 28px;
  }
  .photo-gallery a {
    display: block;
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: var(--bg-tag);
  }
  .photo-gallery img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .photo-gallery a:hover img { transform: scale(1.04); }

  /* Sub-nav items (indented, smaller) */
  .nav-sub {
    padding-left: 28px;
  }
  .nav-sub .nav-item {
    font-size: 13px;
    color: var(--text-tertiary);
    padding: 3px 8px;
  }
  .nav-sub .nav-item:hover { color: var(--text-primary); }

  @media (max-width: 720px) {
    .sidebar { display: none; }
    .main { margin-left: 0; padding: 40px 20px 80px; }
    .columns { grid-template-columns: 1fr; }
    .card-grid { grid-template-columns: 1fr; }
    .prop-key { width: 120px; }
  }
</style>
</head>
