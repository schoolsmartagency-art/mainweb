        <form id="adviser-form" novalidate>

          <!-- Step 1: Channels -->
          <div class="step-panel active" id="step-1">
            <div class="step-title">Опытом в каких направлениях хотите поделиться?</div>
            <p class="step-hint">Отметьте всё, в чём вы работали и получили хоть какой-то результат.</p>

            <div class="channels-grid" id="channels-grid">
              <!-- rendered by JS -->
            </div>
            <p class="field-error" id="channels-error">Выберите хотя бы одно направление</p>

            <div class="btn-row">
              <button type="button" class="btn-primary" onclick="nextStep(1)">
                Далее
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
