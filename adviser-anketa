<style>
:root {
  --red: #E8391D;
  --red-dark: #C42D13;
  --red-glow: rgba(232,57,29,0.18);
  --dark: #111111;
  --dark2: #1A1A1A;
  --dark3: #242424;
  --text: #2C2C2C;
  --muted: #7A7A7A;
  --bg: #F2F3F6;
  --white: #FFFFFF;
  --border: #E4E4E4;
  --accent-bg: #FFF2EF;
  --radius: 14px;
  --radius-lg: 20px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: 'Manrope', sans-serif;
  background: var(--bg);
  color: var(--text);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* ── TICKER ── */
.ticker-wrap {
  background: var(--dark);
  overflow: hidden;
  height: 48px;
  display: flex;
  align-items: center;
  position: relative;
  z-index: 10;
}
.ticker-wrap::before,
.ticker-wrap::after {
  content: '';
  position: absolute;
  top: 0; bottom: 0;
  width: 80px;
  z-index: 2;
  pointer-events: none;
}
.ticker-wrap::before { left: 0; background: linear-gradient(90deg, var(--dark), transparent); }
.ticker-wrap::after  { right: 0; background: linear-gradient(-90deg, var(--dark), transparent); }

.ticker-track {
  display: flex;
  gap: 0;
  animation: ticker 32s linear infinite;
  will-change: transform;
  white-space: nowrap;
}
.ticker-track:hover { animation-play-state: paused; }

@keyframes ticker {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

.ticker-item {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 0 36px;
  font-size: 13px;
  font-weight: 700;
  color: rgba(255,255,255,0.85);
  letter-spacing: -0.01em;
  border-right: 1px solid rgba(255,255,255,0.08);
  height: 48px;
  flex-shrink: 0;
}
.ticker-item .ticker-icon {
  width: 20px; height: 20px;
  color: var(--red);
  flex-shrink: 0;
}
.ticker-item strong { color: var(--white); }

/* ── HERO ── */
.hero {
  background: var(--dark2);
  padding: 72px 24px 80px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  top: -120px; left: 50%;
  transform: translateX(-50%);
  width: 700px; height: 700px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(232,57,29,0.09) 0%, transparent 65%);
  pointer-events: none;
}
.hero-label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(232,57,29,0.12);
  color: #FF7A5C;
  border: 1px solid rgba(232,57,29,0.22);
  border-radius: 100px;
  padding: 6px 18px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  margin-bottom: 24px;
  position: relative;
}
.hero-label-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--red);
  animation: blink 2s infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }

.hero h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(32px, 6vw, 62px);
  font-weight: 900;
  color: var(--white);
  line-height: 1.08;
  letter-spacing: -0.03em;
  margin-bottom: 20px;
  position: relative;
}
.hero h1 em {
  font-style: normal;
  color: var(--red);
}
.hero-sub {
  font-size: clamp(15px, 2vw, 17px);
  color: rgba(255,255,255,0.5);
  max-width: 520px;
  margin: 0 auto 36px;
  line-height: 1.7;
  position: relative;
}
.hero-sub strong { color: rgba(255,255,255,0.85); }

.hero-arrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: rgba(255,255,255,0.3);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.04em;
  position: relative;
  animation: bounce 2s ease-in-out infinite;
}
@keyframes bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(6px)} }

/* ── MAIN LAYOUT ── */
.page-body {
  max-width: 860px;
  margin: 0 auto;
  padding: 0 24px 80px;
}

/* ── SECTION LABEL ── */
.section-label {
  display: inline-block;
  background: var(--accent-bg);
  color: var(--red);
  border-radius: 6px;
  padding: 4px 12px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  margin-bottom: 12px;
}

/* ── FORM CARD ── */
.form-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  border: 1.5px solid var(--border);
  overflow: hidden;
  margin-top: -28px;
  position: relative;
  z-index: 2;
  box-shadow: 0 24px 60px rgba(0,0,0,0.09);
}

.form-card-header {
  background: var(--white);
  padding: 36px 44px 0;
  border-bottom: 1px solid var(--border);
  padding-bottom: 32px;
}

.form-card-header h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(22px, 3.5vw, 30px);
  font-weight: 900;
  color: var(--dark);
  letter-spacing: -0.03em;
  margin-bottom: 6px;
}
.form-card-header p {
  font-size: 14px;
  color: var(--muted);
  line-height: 1.6;
}

/* Step indicator */
.steps-bar {
  display: flex;
  align-items: center;
  gap: 0;
  margin-top: 24px;
}
.step-dot {
  width: 32px; height: 32px;
  border-radius: 50%;
  border: 2px solid var(--border);
  background: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 800;
  color: var(--muted);
  flex-shrink: 0;
  transition: all 0.3s;
  position: relative;
  z-index: 1;
}
.step-dot.active {
  background: var(--red);
  border-color: var(--red);
  color: white;
  box-shadow: 0 4px 12px rgba(232,57,29,0.35);
}
.step-dot.done {
  background: var(--dark);
  border-color: var(--dark);
  color: white;
}
.step-line {
  flex: 1;
  height: 2px;
  background: var(--border);
  position: relative;
}
.step-line-fill {
  position: absolute;
  top: 0; left: 0; bottom: 0;
  background: var(--red);
  transition: width 0.4s ease;
}
.steps-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 8px;
}
.step-label-text {
  font-size: 11px;
  font-weight: 600;
  color: var(--muted);
  text-align: center;
  flex: 1;
  transition: color 0.3s;
}
.step-label-text.active { color: var(--red); }
.step-label-text.done { color: var(--dark); }

/* Form body */
.form-body {
  padding: 36px 44px 40px;
}

/* Step panels */
.step-panel { display: none; }
.step-panel.active { display: block; animation: fadeUp 0.35s ease both; }
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}

.step-title {
  font-size: 18px;
  font-weight: 800;
  color: var(--dark);
  letter-spacing: -0.02em;
  margin-bottom: 6px;
}
.step-hint {
  font-size: 13px;
  color: var(--muted);
  margin-bottom: 24px;
  line-height: 1.55;
}

/* Checkbox grid */
.channels-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 10px;
  margin-bottom: 8px;
}
.channel-item {
  position: relative;
}
.channel-item input[type="checkbox"] {
  position: absolute;
  opacity: 0;
  width: 0; height: 0;
}
.channel-label {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius);
  cursor: pointer;
  transition: all 0.2s;
  background: var(--white);
  user-select: none;
}
.channel-label:hover {
  border-color: rgba(232,57,29,0.35);
  background: var(--accent-bg);
}
input[type="checkbox"]:checked + .channel-label {
  border-color: var(--red);
  background: var(--accent-bg);
  box-shadow: 0 0 0 3px rgba(232,57,29,0.08);
}
.channel-icon-wrap {
  width: 36px; height: 36px;
  border-radius: 9px;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s;
}
input[type="checkbox"]:checked + .channel-label .channel-icon-wrap {
  background: var(--red);
}
.channel-icon-wrap svg {
  width: 18px; height: 18px;
  color: var(--muted);
  transition: color 0.2s;
}
input[type="checkbox"]:checked + .channel-label .channel-icon-wrap svg {
  color: white;
}
.channel-check {
  width: 18px; height: 18px;
  border: 1.5px solid var(--border);
  border-radius: 5px;
  margin-left: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}
input[type="checkbox"]:checked + .channel-label .channel-check {
  background: var(--red);
  border-color: var(--red);
}
.check-mark {
  display: none;
}
input[type="checkbox"]:checked + .channel-label .check-mark {
  display: block;
}
.channel-name {
  font-size: 13px;
  font-weight: 700;
  color: var(--dark);
  line-height: 1.25;
}
.channel-sub {
  font-size: 11px;
  color: var(--muted);
  margin-top: 1px;
}

/* Textarea group */
.textarea-group {
  margin-bottom: 20px;
  animation: fadeUp 0.3s ease both;
}
.textarea-group label {
  display: block;
  font-size: 13px;
  font-weight: 700;
  color: var(--dark);
  margin-bottom: 8px;
  letter-spacing: -0.01em;
}
.textarea-group label span {
  font-size: 11px;
  font-weight: 600;
  color: var(--muted);
  margin-left: 6px;
  background: var(--bg);
  padding: 2px 8px;
  border-radius: 20px;
}
.textarea-group textarea {
  width: 100%;
  min-height: 96px;
  padding: 14px 16px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius);
  font-family: 'Manrope', sans-serif;
  font-size: 14px;
  color: var(--text);
  line-height: 1.6;
  resize: vertical;
  transition: border-color 0.2s, box-shadow 0.2s;
  background: var(--white);
  outline: none;
}
.textarea-group textarea:focus {
  border-color: var(--red);
  box-shadow: 0 0 0 3px rgba(232,57,29,0.08);
}
.textarea-group textarea::placeholder { color: #BCBCBC; }

/* Input group */
.input-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
  margin-bottom: 14px;
}
.input-group {
  display: flex;
  flex-direction: column;
  gap: 7px;
}
.input-group label {
  font-size: 13px;
  font-weight: 700;
  color: var(--dark);
  letter-spacing: -0.01em;
}
.input-group input {
  padding: 13px 16px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius);
  font-family: 'Manrope', sans-serif;
  font-size: 14px;
  color: var(--text);
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
  background: var(--white);
}
.input-group input:focus {
  border-color: var(--red);
  box-shadow: 0 0 0 3px rgba(232,57,29,0.08);
}
.input-group input::placeholder { color: #BCBCBC; }
.input-group.full { grid-column: 1 / -1; }

/* Buttons */
.btn-row {
  display: flex;
  gap: 12px;
  margin-top: 28px;
  align-items: center;
}
.btn-primary {
  background: var(--red);
  color: white;
  border: none;
  border-radius: var(--radius);
  padding: 15px 32px;
  font-family: 'Manrope', sans-serif;
  font-size: 15px;
  font-weight: 800;
  cursor: pointer;
  transition: all 0.22s;
  letter-spacing: -0.01em;
  box-shadow: 0 6px 20px rgba(232,57,29,0.3);
  display: inline-flex;
  align-items: center;
  gap: 8px;
}
.btn-primary:hover {
  background: var(--red-dark);
  transform: translateY(-2px);
  box-shadow: 0 10px 28px rgba(232,57,29,0.38);
}
.btn-primary:active { transform: translateY(0); }
.btn-primary:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
}
.btn-secondary {
  background: none;
  color: var(--muted);
  border: 1.5px solid var(--border);
  border-radius: var(--radius);
  padding: 14px 24px;
  font-family: 'Manrope', sans-serif;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
  letter-spacing: -0.01em;
}
.btn-secondary:hover {
  color: var(--dark);
  border-color: var(--dark);
}

/* Error */
.field-error {
  font-size: 12px;
  color: var(--red);
  font-weight: 600;
  margin-top: 6px;
  display: none;
}
.field-error.show { display: block; }
.error-banner {
  background: #FFF2EF;
  border: 1.5px solid rgba(232,57,29,0.3);
  border-radius: 10px;
  padding: 12px 16px;
  font-size: 13px;
  color: var(--red);
  font-weight: 600;
  margin-bottom: 20px;
  display: none;
}
.error-banner.show { display: block; }

/* ── BENEFITS SECTION ── */
.benefits-section {
  margin-top: 64px;
}
.benefits-section h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(24px, 4vw, 34px);
  font-weight: 900;
  color: var(--dark);
  letter-spacing: -0.03em;
  margin-bottom: 8px;
}
.benefits-section .sub {
  font-size: 15px;
  color: var(--muted);
  line-height: 1.65;
  margin-bottom: 36px;
  max-width: 520px;
}

.benefits-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14px;
}
.benefit-card {
  background: var(--white);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 28px 26px;
  transition: box-shadow 0.2s, transform 0.2s;
}
.benefit-card:hover {
  box-shadow: 0 8px 28px rgba(0,0,0,0.07);
  transform: translateY(-2px);
}
.benefit-card:last-child {
  background: var(--dark2);
  border-color: transparent;
}
.benefit-icon {
  width: 44px; height: 44px;
  border-radius: 11px;
  background: var(--accent-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}
.benefit-icon svg { width: 22px; height: 22px; color: var(--red); }
.benefit-card:last-child .benefit-icon { background: rgba(232,57,29,0.15); }
.benefit-card:last-child .benefit-icon svg { color: #FF7A5C; }
.benefit-card h3 {
  font-size: 16px;
  font-weight: 800;
  color: var(--dark);
  letter-spacing: -0.02em;
  margin-bottom: 6px;
}
.benefit-card:last-child h3 { color: var(--white); }
.benefit-card p {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.62;
}

/* ── THANK YOU ── */
#thank-you {
  display: none;
  min-height: 100vh;
  background: var(--dark2);
  align-items: center;
  justify-content: center;
  padding: 40px 24px;
  text-align: center;
}
#thank-you.show {
  display: flex;
  flex-direction: column;
  animation: fadeUp 0.5s ease both;
}
.ty-icon {
  width: 80px; height: 80px;
  background: rgba(232,57,29,0.12);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 28px;
  animation: scaleIn 0.5s 0.1s ease both;
}
@keyframes scaleIn {
  from { transform: scale(0.5); opacity: 0; }
  to   { transform: scale(1); opacity: 1; }
}
.ty-icon svg { width: 36px; height: 36px; color: var(--red); }
#thank-you h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(28px, 5vw, 46px);
  font-weight: 900;
  color: var(--white);
  letter-spacing: -0.03em;
  margin-bottom: 16px;
  line-height: 1.15;
}
#thank-you h1 em { font-style: normal; color: var(--red); }
#thank-you p {
  font-size: 16px;
  color: rgba(255,255,255,0.5);
  line-height: 1.7;
  max-width: 460px;
  margin: 0 auto 8px;
}
#thank-you p strong { color: rgba(255,255,255,0.8); }
.ty-contact {
  margin-top: 36px;
  display: inline-flex;
  align-items: center;
  gap: 12px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: var(--radius);
  padding: 16px 24px;
}
.ty-contact svg { width: 20px; height: 20px; color: var(--red); flex-shrink: 0; }
.ty-contact-text { text-align: left; }
.ty-contact-text span {
  display: block;
  font-size: 11px;
  font-weight: 700;
  color: rgba(255,255,255,0.35);
  letter-spacing: 0.07em;
  text-transform: uppercase;
  margin-bottom: 3px;
}
.ty-contact-text a {
  font-size: 15px;
  font-weight: 800;
  color: var(--white);
  text-decoration: none;
  transition: color 0.2s;
}
.ty-contact-text a:hover { color: var(--red); }

/* ── RESPONSIVE ── */
@media (max-width: 640px) {
  .form-card-header, .form-body { padding-left: 24px; padding-right: 24px; }
  .channels-grid { grid-template-columns: 1fr 1fr; }
  .input-row { grid-template-columns: 1fr; }
  .benefits-grid { grid-template-columns: 1fr; }
  .benefit-card:last-child { grid-column: auto; }
  .btn-row { flex-direction: column; align-items: stretch; }
  .btn-primary, .btn-secondary { width: 100%; justify-content: center; }
  .steps-labels { display: none; }
}
@media (max-width: 420px) {
  .channels-grid { grid-template-columns: 1fr; }
  .hero h1 { font-size: 28px; }
}
</style>
</head>
