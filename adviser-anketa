          <!-- Step 2: Results -->
          <div class="step-panel" id="step-2">
            <div class="step-title">Расскажите коротко о результатах</div>
            <p class="step-hint">По каждому выбранному направлению — что сделали, чем гордитесь, какие цифры получили.</p>
            <div id="results-fields"></div>
            <div class="btn-row">
              <button type="button" class="btn-primary" onclick="nextStep(2)">
                Далее
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </button>
              <button type="button" class="btn-secondary" onclick="prevStep(2)">Назад</button>
            </div>
          </div>

          <!-- Step 3: Contacts -->
          <div class="step-panel" id="step-3">
            <div class="step-title">Ваши контакты</div>
            <p class="step-hint">Мы свяжемся с вами в Telegram или по телефону в течение нескольких дней.</p>

            <div class="input-row">
              <div class="input-group">
                <label for="f-name">Имя</label>
                <input type="text" id="f-name" name="name" placeholder="Как вас зовут?" autocomplete="given-name">
