            <div class="btn-row">
              <button type="submit" class="btn-primary" id="submit-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Отправить анкету
              </button>
              <button type="button" class="btn-secondary" onclick="prevStep(3)">Назад</button>
            </div>
          </div>

        </form>
      </div>
    </div>

    <!-- Benefits section -->
    <div class="benefits-section">
      <div class="section-label">Что вы получаете</div>
      <h2>Привилегии эдвайзера</h2>
      <p class="sub">Это не просто «спасибо за участие» — реальный доступ к тому, что строится внутри агентства.</p>

      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3>Клуб эдвайзеров</h3>
          <p>Закрытое сообщество практиков. Обмен опытом с теми, кто реально делает результат в трафике и маркетинге для образования.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
          </div>
          <h3>База знаний агентства</h3>
          <p>Все работающие связки, инструменты и решения, которые накапливаются внутри Cantor Agency — доступ раньше всех.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
          </div>
          <h3>Эксклюзивный доступ к услугам</h3>
          <p>Первыми подключите инструменты агентства — Авито, блогеры, VK Ads, Reels — на специальных условиях для эдвайзеров.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 5.66-16.88 5.85m19.5 1.9c-3.5-.93-6.63-.82-8.94 0-2.58.92-5.01 2.86-7.44 6.32"/>
            </svg>
          </div>
          <h3>Амбассадорство</h3>
          <p>Ваш опыт станет частью агентства. Узнаваемость, статус и влияние на рынок образования — ваше имя рядом с Cantor Agency.</p>
        </div>
      </div>
    </div>

  </div><!-- /page-body -->
</div><!-- /main-page -->

<script>
// ── CHANNELS DATA ──
const CHANNELS = [
  { id: 'avito',    name: 'Авито',              sub: 'Агрегатор',   icon: `<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M8 8h8M8 12h6M8 16h4"/>` },
  { id: 'profi',    name: 'Profi.ru',           sub: 'Агрегатор',   icon: `<path d="M20 6h-4V4c0-1.1-.9-2-2-2h-4c-1.1 0-2 .9-2 2v2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zM10 4h4v2h-4V4z"/>` },
  { id: 'reels',    name: 'Reels / Shorts',     sub: 'Видео',       icon: `<polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>` },
  { id: 'bloggers', name: 'Реклама у блогеров', sub: '',   icon: `<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>` },
  { id: 'vk',       name: 'VK Ads',             sub: 'Таргет',      icon: `<path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.03c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"/>` },
  { id: 'yandex',   name: 'Яндекс.Директ',     sub: 'Контекст',    icon: `<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/>` },
  { id: 'telegram', name: 'Telegram',           sub: 'Соцсети',     icon: `<path d="M21.5 2L2 9.5l7 2.5 2.5 7L21.5 2z"/><line x1="9" y1="12" x2="16" y2="5"/>` },
  { id: 'youtube',  name: 'YouTube',            sub: 'Видео',       icon: `<path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>` },
  { id: 'smm',      name: 'SMM / Контент',      sub: 'Соцсети',     icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>` },
  { id: 'funnel',   name: 'Воронки продаж',     sub: 'Автоматизация',icon: `<path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/>` },
  { id: 'other',    name: 'Другое',             sub: 'Иной канал',  icon: `<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/>` },
];

// ── RENDER CHANNELS ──
function renderChannels() {
  const grid = document.getElementById('channels-grid');
  grid.innerHTML = CHANNELS.map(ch => `
    <div class="channel-item">
      <input type="checkbox" id="ch-${ch.id}" name="channel_${ch.id}" value="${ch.name}">
      <label class="channel-label" for="ch-${ch.id}">
        <div class="channel-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${ch.icon}</svg>
        </div>
        <div style="flex:1;min-width:0;">
          <div class="channel-name">${ch.name}</div>
          <div class="channel-sub">${ch.sub}</div>
        </div>
        <div class="channel-check">
          <svg class="check-mark" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
      </label>
    </div>
  `).join('');
}

// ── STEP LOGIC ──
let currentStep = 1;

function getCheckedChannels() {
  return CHANNELS.filter(ch => document.getElementById('ch-'+ch.id)?.checked);
}

function renderResultFields() {
  const checked = getCheckedChannels();
  const container = document.getElementById('results-fields');
  container.innerHTML = checked.map((ch, i) => `
    <div class="textarea-group" style="animation-delay:${i*0.07}s">
      <label for="res-${ch.id}">${ch.name} <span>Коротко о результатах</span></label>
      <textarea id="res-${ch.id}" name="result_${ch.id}" placeholder="Что делали, какой результат получили, чем гордитесь — 2–4 предложения" rows="3"></textarea>
    </div>
  `).join('');
}

function updateStepUI(step) {
  // panels
  document.querySelectorAll('.step-panel').forEach((p,i) => {
    p.classList.toggle('active', i+1 === step);
  });
  // dots
  [1,2,3].forEach(i => {
    const dot = document.getElementById('dot-'+i);
    dot.classList.remove('active','done');
    if (i < step) dot.classList.add('done'), dot.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
    else if (i === step) dot.classList.add('active'), dot.textContent = i;
    else dot.textContent = i;
  });
  // lines
  document.getElementById('line-1').style.width = step > 1 ? '100%' : '0%';
  document.getElementById('line-2').style.width = step > 2 ? '100%' : '0%';
  // labels
  [1,2,3].forEach(i => {
    const lbl = document.getElementById('label-'+i);
    lbl.classList.remove('active','done');
    if (i < step) lbl.classList.add('done');
    else if (i === step) lbl.classList.add('active');
  });
  currentStep = step;
  document.getElementById('error-banner').classList.remove('show');
  // scroll to form
  document.getElementById('form-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function nextStep(from) {
  if (from === 1) {
    const checked = getCheckedChannels();
    if (checked.length === 0) {
      document.getElementById('channels-error').classList.add('show');
      return;
    }
    document.getElementById('channels-error').classList.remove('show');
    renderResultFields();
    updateStepUI(2);
  } else if (from === 2) {
    updateStepUI(3);
  }
}

function prevStep(from) {
  updateStepUI(from - 1);
}

// ── FORM SUBMIT ──
const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbzPk5CHyT_oDsWYZINg_bQTwXg64tJr4-3PugEpi_KU-56ix1lwTmdkkKIUOB-fAOOXeg/exec?sheet=ЭДВАЙЗЕРЫ';

document.getElementById('adviser-form').addEventListener('submit', async (e) => {
  e.preventDefault();

  // Validate step 3
  let valid = true;
  const name = document.getElementById('f-name').value.trim();
  const phone = document.getElementById('f-phone').value.trim();
  const tg = document.getElementById('f-tg').value.trim();

  document.getElementById('name-error').classList.toggle('show', !name);
  document.getElementById('phone-error').classList.toggle('show', !phone);
  document.getElementById('tg-error').classList.toggle('show', !tg);
  if (!name || !phone || !tg) {
    document.getElementById('error-banner').classList.add('show');
    return;
  }

  const btn = document.getElementById('submit-btn');
  btn.disabled = true;
  btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> Отправка...`;

  try {
    const formData = new FormData(e.target);
    // Collect checked channels as readable string
    const channels = getCheckedChannels().map(c => c.name).join(', ');
    formData.append('channels', channels);

    // Collect result fields
    getCheckedChannels().forEach(ch => {
      const val = document.getElementById('res-'+ch.id)?.value?.trim() || '';
      formData.append('result_' + ch.name, val);
    });

    const response = await fetch(SCRIPT_URL, { method: 'POST', body: formData });
    const result = await response.json();

    if (result.result === 'success') {
      document.getElementById('main-page').style.display = 'none';
      document.getElementById('thank-you').classList.add('show');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    } else {
      throw new Error(result.error || 'Unknown error');
    }
  } catch (err) {
    console.error(err);
    document.getElementById('error-banner').textContent = 'Ошибка отправки. Попробуйте ещё раз или напишите напрямую: @oleg_ezhkov';
    document.getElementById('error-banner').classList.add('show');
    btn.disabled = false;
    btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Отправить анкету`;
  }
});

// ── INIT ──
renderChannels();
</script>
</body>
</html>
