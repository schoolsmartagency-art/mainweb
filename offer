.wrap{max-width:780px;margin:0 auto;padding:48px 24px 80px}

.doc-title{font-size:28px;font-weight:700;color:var(--dark);margin-bottom:8px;letter-spacing:-0.02em;line-height:1.2}
.doc-meta{font-size:13px;color:var(--muted);margin-bottom:40px}

h2{font-size:17px;font-weight:700;color:var(--dark);margin:32px 0 10px;letter-spacing:-0.01em}
