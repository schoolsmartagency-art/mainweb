.section{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:24px 28px;margin-bottom:16px}
.price-table{width:100%;border-collapse:collapse;margin:16px 0 8px}
.price-table th,.price-table td{border-bottom:1px solid var(--border);padding:12px 0;text-align:left;font-size:14px}
.price-table th{font-weight:600;color:var(--dark)}
.price-table td{color:var(--text)}
.price-table tr:last-child td{border-bottom:none}

.requisites{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:24px 28px;margin-top:32px}
.req-title{font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:var(--muted);margin-bottom:16px}
.req-row{display:flex;gap:16px;font-size:14px;padding:8px 0;border-bottom:1px solid var(--border)}
.req-row:last-child{border-bottom:none}
.req-label{min-width:200px;color:var(--muted);flex-shrink:0}
.req-val{color:var(--dark);font-weight:500}

footer{text-align:center;padding:20px;font-size:12px;color:var(--muted)}

@media(max-width:600px){
