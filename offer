<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --red:#E8391D;
  --dark:#0F0F0F;
  --text:#1C1C1C;
  --muted:#888;
  --bg:#F6F5F2;
  --white:#FFFFFF;
