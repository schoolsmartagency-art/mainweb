body{font-family:'Geologica',sans-serif;color:var(--text);background:var(--bg);line-height:1.7;-webkit-font-smoothing:antialiased}

.header{background:var(--white);border-bottom:1px solid var(--border);padding:18px 40px;display:flex;align-items:center}
.logo{font-size:16px;font-weight:700;color:var(--dark);text-decoration:none;letter-spacing:-0.01em}
