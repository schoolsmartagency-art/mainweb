<script>
const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbzPk5CHyT_oDsWYZINg_bQTwXg64tJr4-3PugEpi_KU-56ix1lwTmdkkKIUOB-fAOOXeg/exec?sheet=КЛУБ';

const TOTAL_STEPS = 7;
const progressPct = {1:14,2:28,3:42,4:57,5:71,6:85,7:100};

const state = {
  currentStep: 1,
  services: [],
  role: '',
  format: '',
  income: '',
  trafficBudget: '',
  toolsExp: '',
  summerBudget: '',
  sales: ''
};

const svcNames = {avito:'Авито',profi:'Профи.ру',bloggers:'Реклама у блогеров',website:'Сайт-визитка'};
const roleNames = {tutor:'Репетитор',school:'Онлайн-школа'};
const formatNames = {online:'Онлайн',offline:'Офлайн',both:'Оба формата'};
const audienceNames = {school_low:'1–4 кл.',school_mid:'5–9 кл.',school_high:'10–11 кл. (ЕГЭ/ОГЭ)',students:'Студенты',adults:'Взрослые',mixed:'Разные группы'};
const incomeNames = {'0-50':'До 50 тыс. ₽','50-150':'50–150 тыс. ₽','150-400':'150–400 тыс. ₽','400-1m':'400 тыс. — 1 млн ₽','1m+':'Более 1 млн ₽'};
const tbNames = {'0':'Не трачу','1-10k':'До 10 тыс. ₽','10-30k':'10–30 тыс. ₽','30-100k':'30–100 тыс. ₽','100k+':'Более 100 тыс. ₽'};
const ltvNames = {'1-2':'1–2 мес.','3-5':'3–5 мес.','6-11':'6–11 мес.','12+':'Год и более'};
const sbNames = {'0-10k':'До 10 тыс. ₽','10-30k':'10–30 тыс. ₽','30-80k':'30–80 тыс. ₽','80k+':'Более 80 тыс. ₽'};
const salesNames = {self:'Сам',manager:'Менеджер/помощник',team:'Отдел продаж',bot:'Автоматизация/бот'};
const toolsExpNames = {
  no: 'Не пробовал',
  some: 'Некоторые пробовал',
  all: 'Все или почти все',
  tried_avito: 'Пробовал Авито',
  tried_profi: 'Пробовал Профи.ру',
  tried_bloggers: 'Пробовал рекламу у блогеров',
  tried_website: 'Пробовал сайт'
};

function goTo(step) {
  if (step > state.currentStep && !validateStep(state.currentStep)) return;
  document.getElementById('step' + state.currentStep).classList.remove('active');
  state.currentStep = step;
  document.getElementById('step' + step).classList.add('active');
  document.getElementById('progressFill').style.width = progressPct[step] + '%';
  document.getElementById('stepLabel').textContent = 'Шаг ' + step;
  document.getElementById('stepCounter').textContent = step + ' / ' + TOTAL_STEPS;
  if (step === 5) buildStep5();
}

function toggleSvc(el) {
  const id = el.dataset.id;
  el.classList.toggle('selected');
  if (el.classList.contains('selected')) { 
    if (!state.services.includes(id)) state.services.push(id); 
  } else { 
    state.services = state.services.filter(s => s !== id); 
  }
  if (state.services.length > 0) document.getElementById('svcErr').style.display = 'none';
}

function toggleDet(btn) {
  const details = btn.nextElementSibling;
  details.classList.toggle('open');
  btn.classList.toggle('open');
  btn.childNodes[0].nodeValue = details.classList.contains('open') ? 'Скрыть ' : 'Подробнее ';
}

function buildStep5() {
  const names = state.services.map(s => svcNames[s]);
  document.getElementById('selectedSvcReminder').textContent = names.join(', ');
  const list = document.getElementById('toolsExpList');
  list.innerHTML = '';
  list.innerHTML += `<div class="opt-item" onclick="selectOpt(this,'toolsExp','no')"><div class="opt-radio"><div class="opt-dot"></div></div><div><div class="opt-text">Нет, ни один не пробовал</div></div></div>`;
  if (state.services.length > 1) {
    list.innerHTML += `<div class="opt-item" onclick="selectOpt(this,'toolsExp','some')"><div class="opt-radio"><div class="opt-dot"></div></div><div><div class="opt-text">Да, некоторые пробовал</div></div></div>`;
  }
  state.services.forEach(s => {
    list.innerHTML += `<div class="opt-item" onclick="selectOpt(this,'toolsExp','tried_${s}')"><div class="opt-radio"><div class="opt-dot"></div></div><div><div class="opt-text">Да, пробовал ${svcNames[s]}</div></div></div>`;
  });
  if (state.services.length > 1) {
    list.innerHTML += `<div class="opt-item" onclick="selectOpt(this,'toolsExp','all')"><div class="opt-radio"><div class="opt-dot"></div></div><div><div class="opt-text">Да, пробовал всё из выбранного</div></div></div>`;
  }
  state.toolsExp = '';
}

function selectRole(el, val) {
  document.querySelectorAll('.role-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  state.role = val;
  document.getElementById('roleErr').style.display = 'none';
  const isTutor = val === 'tutor';
  document.getElementById('tutorFields').style.display = isTutor ? 'block' : 'none';
  document.getElementById('schoolFields').style.display = isTutor ? 'none' : 'block';
  document.getElementById('s3title').textContent = isTutor ? 'О вашей практике' : 'О вашей школе';
  document.getElementById('s3sub').textContent = isTutor
    ? 'Расскажите о предмете, аудитории и формате работы.'
    : 'Расскажите о школе, продуктах и экономике.';
}

function selectOpt(el, name, value) {
  const parent = el.parentElement;
  parent.querySelectorAll('.opt-item').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  state[name] = value;
  const errEl = document.getElementById(name + 'Err');
  if (errEl) errEl.style.display = 'none';
}

function validateStep(step) {
  if (step === 1) {
    if (!state.services.length) { document.getElementById('svcErr').style.display = 'block'; return false; }
    return true;
  }
  if (step === 2) {
    if (!state.role) { document.getElementById('roleErr').style.display = 'block'; return false; }
    return true;
  }
  if (step === 3) {
    let ok = true;
    if (state.role === 'tutor') {
      if (!val('subject')) { err('f-subject'); ok = false; } else noErr('f-subject');
      if (!val('audience')) { err('f-audience'); ok = false; } else noErr('f-audience');
      if (!val('checkTutor')) { err('f-check-tutor'); ok = false; } else noErr('f-check-tutor');
      if (!val('ltvTutor')) { err('f-ltv-tutor'); ok = false; } else noErr('f-ltv-tutor');
    } else {
      if (!val('schoolName')) { err('f-school-name'); ok = false; } else noErr('f-school-name');
      if (!val('schoolProducts')) { err('f-school-products'); ok = false; } else noErr('f-school-products');
      if (!val('schoolCheck')) { err('f-school-check'); ok = false; } else noErr('f-school-check');
      if (!val('schoolLtv')) { err('f-school-ltv'); ok = false; } else noErr('f-school-ltv');
    }
    return ok;
  }
  if (step === 4) {
    let ok = true;
    if (!state.income) { document.getElementById('incomeErr').style.display = 'block'; ok = false; } else document.getElementById('incomeErr').style.display = 'none';
    if (!state.trafficBudget) { document.getElementById('trafficBudgetErr').style.display = 'block'; ok = false; } else document.getElementById('trafficBudgetErr').style.display = 'none';
    return ok;
  }
  if (step === 5) {
    let ok = true;
    if (!state.toolsExp) { document.getElementById('toolsExpErr').style.display = 'block'; ok = false; } else document.getElementById('toolsExpErr').style.display = 'none';
    if (!state.summerBudget) { document.getElementById('summerBudgetErr').style.display = 'block'; ok = false; } else document.getElementById('summerBudgetErr').style.display = 'none';
    return ok;
  }
  if (step === 6) {
    if (!state.sales) { document.getElementById('salesErr').style.display = 'block'; return false; } else document.getElementById('salesErr').style.display = 'none';
    return true;
  }
  if (step === 7) {
    let ok = true;
    ['name','tg','phone'].forEach(id => {
      if (!val(id)) { err('f-' + id); ok = false; } else noErr('f-' + id);
    });
    return ok;
  }
  return true;
}

function val(id) { const el = document.getElementById(id); return el && el.value.trim(); }
function err(fid) { const el = document.getElementById(fid); if(el) el.classList.add('error'); }
function noErr(fid) { const el = document.getElementById(fid); if(el) el.classList.remove('error'); }

function submitForm() {
  if (!validateStep(7)) return;
  document.getElementById('loadingOverlay').classList.add('active');
  const btn = document.getElementById('submitBtn');
  btn.disabled = true;

  const fd = new FormData();
  fd.append('timestamp', new Date().toLocaleString('ru-RU'));
  fd.append('services', state.services.map(s => svcNames[s]).join(', '));
  fd.append('role', roleNames[state.role] || '');
  fd.append('subject', val('subject') || '');
  fd.append('audience', audienceNames[val('audience')] || '');
  fd.append('check_tutor', val('checkTutor') || '');
  fd.append('ltv_tutor', val('ltvTutor') || '');
  fd.append('school_name', val('schoolName') || '');
  fd.append('school_products', val('schoolProducts') || '');
  fd.append('school_check', val('schoolCheck') || '');
  fd.append('school_ltv', val('schoolLtv') || '');
  fd.append('income', incomeNames[state.income] || '');
  fd.append('traffic_budget', tbNames[state.trafficBudget] || '');
  fd.append('channels', val('channels') || '');
  fd.append('tools_exp', toolsExpNames[state.toolsExp] || '');
  fd.append('tools_results', val('toolsResults') || '');
  fd.append('summer_budget', sbNames[state.summerBudget] || '');
  fd.append('sales', salesNames[state.sales] || '');
  fd.append('site_url', val('siteUrl') || '');
  fd.append('social_url', val('socialUrl') || '');
  fd.append('name', val('name') || '');
  fd.append('telegram', val('tg') || '');
  fd.append('phone', val('phone') || '');
  fd.append('comment', val('comment') || '');

  fetch(APPS_SCRIPT_URL, { method: 'POST', body: fd })
    .then(r => r.json())
    .then(res => {
      document.getElementById('loadingOverlay').classList.remove('active');
      if (res.result === 'success') { showThanks(); }
      else { alert('Ошибка при отправке. Попробуйте ещё раз или напишите https://t.me/oleg_ezhkov'); btn.disabled = false; }
    })
    .catch(() => {
      document.getElementById('loadingOverlay').classList.remove('active');
      alert('Ошибка соединения. Проверьте интернет и попробуйте снова. Или напишите https://t.me/oleg_ezhkov');
      btn.disabled = false;
    });
}

function showThanks() {
  document.getElementById('step7').classList.remove('active');
  document.getElementById('thankYou').classList.add('active');
  document.getElementById('progressFill').style.width = '100%';
  document.getElementById('stepLabel').textContent = 'Готово';
  document.getElementById('stepCounter').textContent = '✓';
}
</script>
