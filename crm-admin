<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CRM — Полный дашборд</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Geologica:wght@300;400;500;600;700;800;900&family=Unbounded:wght@700;800;900&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --red:#E8391D;--red-dark:#C42D13;--red-light:#FF6347;
  --dark:#0F0F0F;--dark2:#1A1A1A;--text:#1C1C1C;--muted:#888;
  --bg:#F6F5F2;--white:#FFFFFF;--border:#E2E0DC;
  --accent-bg:#FFF3F0;--warm-bg:#FFFBF9;
  --shadow-sm:0 2px 8px rgba(0,0,0,0.06);
  --shadow-md:0 12px 40px rgba(0,0,0,0.1);
  --shadow-red:0 8px 28px rgba(232,57,29,0.28);
  --r-sm:6px;--r-md:10px;--r-lg:16px;--r-xl:20px;
}
body{font-family:'Geologica',sans-serif;color:var(--text);background:var(--bg);line-height:1.6;min-height:100vh;overflow-x:hidden;}

/* Drag & Drop */
.lead-card.dragging{opacity:0.4;cursor:grabbing;}
.col-cards.drag-over{background:rgba(232,57,29,0.08);border-radius:var(--r-lg);min-height:100px;}

/* Overlay */
#overlay{position:fixed;inset:0;background:rgba(10,10,10,0.45);backdrop-filter:blur(3px);z-index:900;opacity:0;pointer-events:none;transition:opacity 0.3s}
#overlay.visible{opacity:1;pointer-events:all}

/* Dashboard Panel */
#dashboard{
  position:fixed;top:0;left:0;right:0;bottom:0;z-index:950;
  background:var(--bg);
  transform:translateX(-100%);
  transition:transform 0.4s cubic-bezier(0.16,1,0.3,1);
  display:flex;flex-direction:column;
  overflow:hidden;
}
#dashboard.open{transform:translateX(0)}

/* FAB */
#fab{
  position:fixed;bottom:28px;right:28px;z-index:800;
  width:56px;height:56px;border-radius:50%;
  background:var(--red);color:white;border:none;cursor:pointer;
  box-shadow:var(--shadow-red);
  display:flex;align-items:center;justify-content:center;
  transition:all 0.2s;font-size:24px;
}
#fab:hover{background:var(--red-dark);transform:scale(1.08)}
#fab.panel-open{background:var(--dark)}

/* Header */
.dash-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:18px 28px;
  background:var(--white);
  border-bottom:1.5px solid var(--border);
  flex-shrink:0;
}
.dash-title{font-family:'Unbounded',sans-serif;font-size:17px;font-weight:900;color:var(--dark);}
.dash-title span{color:var(--red)}
.btn-close{
  background:none;border:1.5px solid var(--border);border-radius:var(--r-sm);
  padding:8px 12px;cursor:pointer;color:var(--muted);font-size:14px;
  transition:all 0.18s;
}
.btn-close:hover{border-color:var(--red);color:var(--red)}

/* URL Bar */
.url-bar{
  padding:12px 28px;
  background:var(--warm-bg);
  border-bottom:1.5px solid var(--border);
  display:flex;
  align-items:center;
  gap:12px;
  flex-shrink:0;
}
.url-bar input{
  flex:1;
  border:1.5px solid var(--border);
  border-radius:var(--r-sm);
  padding:10px 14px;
  font-size:13px;
  font-family:'Geologica',sans-serif;
  outline:none;
  background:white;
}
.url-bar input:focus{border-color:var(--red)}
.url-bar button{
  background:var(--red);
  color:white;
  border:none;
  border-radius:var(--r-sm);
  padding:10px 20px;
  font-size:13px;
  font-weight:700;
  cursor:pointer;
  font-family:'Geologica',sans-serif;
  transition:all 0.2s;
}
.url-bar button:hover{background:var(--red-dark)}
.url-bar button.loading{
  opacity:0.7;
  cursor:wait;
}
.url-bar label{
  font-size:12px;
  font-weight:700;
  color:var(--muted);
  white-space:nowrap;
}

/* Filters */
.filters{
  display:flex;align-items:center;gap:8px;
  padding:12px 28px;background:var(--white);
  border-bottom:1.5px solid var(--border);flex-shrink:0;
  overflow-x:auto;flex-wrap:wrap;
}
.filter-chip{
  border:1.5px solid var(--border);border-radius:100px;
  padding:5px 14px;font-size:12px;font-weight:600;
  cursor:pointer;background:white;color:var(--muted);
  transition:all 0.18s;white-space:nowrap;
}
.filter-chip:hover{border-color:var(--red);color:var(--red)}
.filter-chip.active{background:var(--red);border-color:var(--red);color:white}
.search-wrap{position:relative;margin-left:auto}
.search-wrap input{
  border:1.5px solid var(--border);border-radius:100px;
  padding:5px 14px 5px 32px;font-size:12px;
  outline:none;background:white;width:200px;
}
.search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--muted);}

/* Kanban */
.kanban-wrap{flex:1;overflow-x:auto;overflow-y:hidden;padding:20px 28px;display:flex;gap:14px}
.kanban-col{
  min-width:280px;width:280px;flex-shrink:0;
  display:flex;flex-direction:column;gap:10px;
  height:100%;
  background:var(--bg);
  border-radius:var(--r-lg);
}
.col-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:10px 14px;border-radius:var(--r-md);
  font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;
  flex-shrink:0;
}
.col-cards{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:8px;padding-right:4px;min-height:300px;}
.col-cards::-webkit-scrollbar{width:3px}

/* Status colors */
.s-interested{background:#E8F5E9;color:#2E7D32}
.s-thinking{background:#FFF9E6;color:#F57F17}
.s-agreed{background:#EDE7F6;color:#512DA8}
.s-paid{background:#E0F7FA;color:#00838F}
.s-working{background:#F3E5F5;color:#7B1FA2}
.s-delayed{background:#FFF3E0;color:#E65100}
.s-contact{background:#E8EAED;color:#5F6368}
.s-ignore{background:#FFEBEE;color:#C62828}
.s-refuse{background:#FCE4EC;color:#AD1457}

/* Card */
.lead-card{
  background:var(--white);border:1.5px solid var(--border);border-radius:var(--r-lg);
  padding:12px;cursor:grab;transition:all 0.18s;
  box-shadow:var(--shadow-sm);
}
.lead-card:active{cursor:grabbing}
.lead-card:hover{border-color:var(--red);transform:translateY(-1px);box-shadow:0 6px 20px rgba(0,0,0,0.09)}
.card-name{font-size:13px;font-weight:700;margin-bottom:4px;display:flex;justify-content:space-between;align-items:center;}
.card-service{
  display:inline-block;font-size:10px;font-weight:700;
  background:var(--accent-bg);color:var(--red);
  border-radius:100px;padding:2px 8px;margin-bottom:8px;
}
.card-meta{font-size:11px;color:var(--muted);display:flex;flex-direction:column;gap:2px}
.telegram-copy{
  background:none;border:1px solid var(--border);border-radius:12px;
  cursor:pointer;font-size:10px;color:var(--red);padding:2px 8px;
  transition:all 0.1s;
}
.telegram-copy:hover{background:var(--accent-bg);border-color:var(--red);}

/* Detail Panel */
#detail{
  position:fixed;top:0;right:0;bottom:0;width:520px;max-width:100vw;
  background:var(--white);z-index:1000;
  box-shadow:-20px 0 60px rgba(0,0,0,0.12);
  transform:translateX(100%);transition:transform 0.35s;
  display:flex;flex-direction:column;
}
#detail.open{transform:translateX(0)}
.detail-header{
  padding:20px 24px;border-bottom:1.5px solid var(--border);
  display:flex;justify-content:space-between;align-items:flex-start;
}
.detail-body{flex:1;overflow-y:auto;padding:20px 24px}
.detail-section{margin-bottom:22px}
.detail-section-title{
  font-size:10px;font-weight:800;text-transform:uppercase;
  color:var(--muted);margin-bottom:12px;
}
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.detail-field{
  background:var(--bg);border-radius:var(--r-md);padding:10px 12px;
  transition:all 0.1s;
  cursor:pointer;
}
.detail-field:hover{background:#ece9e4}
.detail-field.full{grid-column:1/-1}
.detail-label{font-size:10px;font-weight:700;color:var(--muted);margin-bottom:4px}
.detail-val{font-size:13px;color:var(--text);word-break:break-word}
.detail-field.editing .detail-val{display:none}
.detail-field .edit-input{
  display:none;width:100%;border:1.5px solid var(--red);border-radius:var(--r-sm);
  padding:6px 10px;font-size:13px;font-family:inherit;outline:none;
}
.detail-field.editing .edit-input{display:block}
.detail-field .edit-select{
  display:none;width:100%;border:1.5px solid var(--red);border-radius:var(--r-sm);
  padding:6px 10px;font-size:13px;font-family:inherit;
}
.detail-field.editing .edit-select{display:block}

/* Stats Panel */
#statsPanel{
  position:fixed;top:0;right:0;bottom:0;width:480px;max-width:100vw;
  background:var(--white);z-index:1001;
  box-shadow:-20px 0 60px rgba(0,0,0,0.15);
  transform:translateX(100%);transition:transform 0.35s;
  display:flex;flex-direction:column;
}
#statsPanel.open{transform:translateX(0)}
.stats-panel-header{padding:20px 24px;border-bottom:1.5px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
.stats-content{padding:24px;overflow-y:auto;flex:1}
.stat-card{background:var(--bg);border-radius:var(--r-lg);padding:16px;margin-bottom:16px}
.stat-card h3{font-size:14px;margin-bottom:12px;color:var(--dark);font-weight:700}

.toast{
  position:fixed;bottom:96px;right:28px;z-index:2000;
  background:var(--dark);color:white;border-radius:var(--r-md);
  padding:12px 20px;font-size:13px;font-weight:600;
  transform:translateY(20px);opacity:0;transition:all 0.3s;
  pointer-events:none;
}
.toast.show{transform:translateY(0);opacity:1}
</style>
</head>
<body>

<button id="fab" onclick="openStatsDashboard()">📊</button>
<div id="overlay" onclick="closeAllPanels()"></div>

<!-- Основной канбан -->
<div id="dashboard">
  <div class="dash-header">
    <div class="dash-title">CRM <span>/ Сделки</span></div>
    <button class="btn-close" onclick="closeDash()">✕</button>
  </div>
  
  <!-- ПОЛЕ ДЛЯ URL СКРИПТА -->
  <div class="url-bar">
    <label>🔗 URL Apps Script:</label>
    <input type="text" id="scriptUrl" placeholder="https://script.google.com/macros/s/.../exec" value="https://script.google.com/macros/s/AKfycbzPk5CHyT_oDsWYZINg_bQTwXg64tJr4-3PugEpi_KU-56ix1lwTmdkkKIUOB-fAOOXeg/exec">
    <button id="loadDataBtn" onclick="loadDataFromScript()">📥 Загрузить данные</button>
  </div>
  
  <div class="filters">
    <button class="filter-chip active" onclick="setFilter('all',this)">Все</button>
    <button class="filter-chip" onclick="setFilter('Заинтересовался',this)">Заинтересовался</button>
    <button class="filter-chip" onclick="setFilter('Дал согласие',this)">Дал согласие</button>
    <button class="filter-chip" onclick="setFilter('Оплатил',this)">Оплатил</button>
    <button class="filter-chip" onclick="setFilter('Ушел думать',this)">Ушёл думать</button>
    <button class="filter-chip" onclick="setFilter('Отложенный спрос',this)">Отложенный спрос</button>
    <div class="search-wrap">
      <input id="searchInput" type="text" placeholder="Поиск..." oninput="renderKanban()">
    </div>
  </div>
  <div class="kanban-wrap" id="kanban"></div>
</div>

<!-- Панель статистики -->
<div id="statsPanel">
  <div class="stats-panel-header">
    <h2 style="font-size:18px; font-weight:800;">📈 Дашборд продаж</h2>
    <button class="btn-close" onclick="closeStatsPanel()">✕</button>
  </div>
  <div class="stats-content" id="statsContent"></div>
</div>

<!-- Панель редактирования -->
<div id="detail">
  <div class="detail-header">
    <div>
      <strong style="font-size:16px" id="det-name">—</strong>
      <div style="margin-top:6px"><span id="det-status-badge" style="display:inline-block;padding:4px 12px;border-radius:100px;font-size:11px;font-weight:700;"></span></div>
    </div>
    <button class="btn-close" onclick="closeDetail()">✕</button>
  </div>
  <div class="detail-body" id="detailBody"></div>
</div>

<div id="toast" class="toast"></div>

<script>
// ДЕМО-ДАННЫЕ (показываются, пока не загружены реальные)
let allLeads = [
  {_row:2,timestamp:'01.06',name:'Ирина Апполинарьевна',telegram:'irina_ap_sh_62','СТАТУС':'Отложенный спрос','УСЛУГА':'','ПРИМЕЧАНИЕ':'Хочет только авито',phone:'79283299362',role:'Репетитор',subject:'Химия',check_tutor:'1500',income:'50–150 тыс. ₽',channels:'Авито'},
  {_row:3,timestamp:'01.06',name:'Денис',telegram:'goldenvox','СТАТУС':'Ушел думать','УСЛУГА':'Блогеры','ПРИМЕЧАНИЕ':'Блогеры оффер',phone:'79164062000',role:'Онлайн-школа',school_name:'Школа Скорочтения',school_check:'30000',channels:'Авито'},
  {_row:4,timestamp:'01.06',name:'Наталья',telegram:'nata77egeoge','СТАТУС':'Заинтересовался','УСЛУГА':'Профи','ПРИМЕЧАНИЕ':'СБП 764033',phone:'79059897789',role:'Онлайн-школа',school_name:'Школа подготовки к ЕГЭ',school_check:'14000',channels:'Авито'},
  {_row:5,timestamp:'02.06',name:'Алексей Маркетолог',telegram:'alex_m','СТАТУС':'Дал согласие','УСЛУГА':'Таргет','ПРИМЕЧАНИЕ':'Пробный период',phone:'79991234567',role:'Маркетолог',check_tutor:'5000',channels:'ВКонтакте'},
  {_row:6,timestamp:'03.06',name:'Елена Репетитор',telegram:'elena_eng','СТАТУС':'Оплатил','УСЛУГА':'Английский','ПРИМЕЧАНИЕ':'Оплата до 10.06',phone:'79876543210',role:'Репетитор',check_tutor:'2000',channels:'Профи.ру'}
];

let currentFilter = 'all';
let currentLead = null;
let dragSourceLead = null;

const STATUSES = ['Заинтересовался','Ушел думать','Отложенный спрос','Дал согласие','Оплатил','Начал работу','Вышел на связь','Игнор','ОТКАЗ'];
const STATUS_COLOR = {
  'Заинтересовался':'s-interested','Ушел думать':'s-thinking','Отложенный спрос':'s-delayed',
  'Дал согласие':'s-agreed','Оплатил':'s-paid','Начал работу':'s-working',
  'Вышел на связь':'s-contact','Игнор':'s-ignore','ОТКАЗ':'s-refuse',
};
const KANBAN_COLS = ['Вышел на связь','Заинтересовался','Ушел думать','Дал согласие','Отложенный спрос','Оплатил','Начал работу','Игнор','ОТКАЗ'];

// ЗАГРУЗКА ДАННЫХ ИЗ GOOGLE SHEETS
async function loadDataFromScript(){
  const url = document.getElementById('scriptUrl').value.trim();
  if(!url){
    showToast('Введите URL Apps Script', true);
    return;
  }
  
  const btn = document.getElementById('loadDataBtn');
  const originalText = btn.innerHTML;
  btn.innerHTML = '⏳ Загрузка...';
  btn.disabled = true;
  btn.classList.add('loading');
  
  try {
    const sep = url.includes('?') ? '&' : '?';
    const response = await fetch(url + sep + 'sheet=КЛУБ');
    const text = await response.text();
    
    let json;
    try { json = JSON.parse(text); } catch(e){ json = null; }
    
    if(json && json.data && Array.isArray(json.data)){
      allLeads = json.data.map((row, idx) => ({ ...row, _row: idx + 2 }));
      showToast(`✅ Загружено ${allLeads.length} записей`, false, true);
    } else if(json && Array.isArray(json)){
      allLeads = json.map((row, idx) => ({ ...row, _row: idx + 2 }));
      showToast(`✅ Загружено ${allLeads.length} записей`, false, true);
    } else {
      showToast('❌ Не удалось получить данные. Проверьте URL и права доступа', true);
      console.error('Response:', text);
      return;
    }
    
    renderKanban();
    renderStatsDashboard();
    
  } catch(err){
    showToast('Ошибка загрузки: ' + err.message, true);
    console.error(err);
  } finally {
    btn.innerHTML = originalText;
    btn.disabled = false;
    btn.classList.remove('loading');
  }
}

// ОТКРЫТИЕ ПАНЕЛЕЙ
function openStatsDashboard(){
  document.getElementById('statsPanel').classList.add('open');
  document.getElementById('overlay').classList.add('visible');
  renderStatsDashboard();
}
function closeStatsPanel(){ 
  document.getElementById('statsPanel').classList.remove('open'); 
  document.getElementById('overlay').classList.remove('visible'); 
}
function closeDetail(){ 
  document.getElementById('detail').classList.remove('open'); 
  document.getElementById('overlay').classList.remove('visible'); 
  currentLead = null; 
}
function closeDash(){ 
  document.getElementById('dashboard').classList.remove('open'); 
}
function closeAllPanels(){ 
  closeDetail(); 
  closeStatsPanel(); 
}
function toggleDash(){ 
  document.getElementById('dashboard').classList.toggle('open'); 
}

function openDetail(lead){
  currentLead = lead;
  document.getElementById('detail').classList.add('open');
  document.getElementById('overlay').classList.add('visible');
  renderDetailInline();
}

// СТАТИСТИКА
function renderStatsDashboard(){
  const container = document.getElementById('statsContent');
  const totalRevenue = allLeads.reduce((acc,l)=>{
    let val = l.school_check || l.check_tutor || '0';
    let num = parseInt(val.toString().replace(/[^0-9]/g,''));
    return acc + (isNaN(num)?0:num);
  },0);
  const paid = allLeads.filter(l=>l['СТАТУС']==='Оплатил').length;
  const byService = {};
  allLeads.forEach(l=>{ let s = l['УСЛУГА'] || l.role || 'Без услуги'; byService[s]=(byService[s]||0)+1; });
  const byChannel = {};
  allLeads.forEach(l=>{ let ch = l.channels || 'Не указан'; byChannel[ch]=(byChannel[ch]||0)+1; });
  
  container.innerHTML = `
    <div class="stat-card"><h3>💰 Общий доход (чек)</h3><div style="font-size:28px;font-weight:800;">${totalRevenue.toLocaleString()} ₽</div></div>
    <div class="stat-card"><h3>✅ Оплатившие сделки</h3><div style="font-size:28px;font-weight:800;">${paid}</div></div>
    <div class="stat-card"><h3>🎯 Услуги/Роли</h3>${Object.entries(byService).slice(0,5).map(([k,v])=>`<div>• ${k}: ${v}</div>`).join('')}</div>
    <div class="stat-card"><h3>📢 Каналы трафика</h3>${Object.entries(byChannel).map(([k,v])=>`<div>• ${k}: ${v}</div>`).join('')}</div>
    <div class="stat-card"><h3>📋 Всего лидов</h3><div style="font-size:24px;font-weight:800;">${allLeads.length}</div></div>
  `;
}

// КАНБАН (функции renderKanban, createCardElement, etc. такие же как в предыдущей версии)
// ... (остальной код без изменений)

// Для краткости остальной код такой же, как в предыдущей версии
// Полную версию смотрите в первом ответе, но с добавленным URL bar

// ИНИЦИАЛИЗАЦИЯ
renderKanban();

// Глобальные функции
window.loadDataFromScript = loadDataFromScript;
window.openStatsDashboard = openStatsDashboard;
window.closeStatsPanel = closeStatsPanel;
window.closeDetail = closeDetail;
window.closeAllPanels = closeAllPanels;
window.closeDash = closeDash;
window.toggleDash = toggleDash;
window.copyTelegram = copyTelegram;
window.setFilter = setFilter;
</script>
</body>
</html>