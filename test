<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Котики</title>
<style>
  body {
    margin: 0;
    padding: 40px 20px;
    background: #111;
    color: #fff;
    font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
    text-align: center;
  }
  h1 {
    font-size: 2rem;
    margin-bottom: 30px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px;
    max-width: 1000px;
    margin: 0 auto;
  }
  .grid img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    border-radius: 12px;
    display: block;
  }
</style>
</head>
<body>
  <h1>🐱 Котики дня</h1>
  <div class="grid">
    <img src="https://cataas.com/cat?width=400&height=400&t=1" alt="Котик 1" loading="lazy">
    <img src="https://cataas.com/cat?width=400&height=400&t=2" alt="Котик 2" loading="lazy">
    <img src="https://cataas.com/cat?width=400&height=400&t=3" alt="Котик 3" loading="lazy">
    <img src="https://cataas.com/cat?width=400&height=400&t=4" alt="Котик 4" loading="lazy">
    <img src="https://cataas.com/cat?width=400&height=400&t=5" alt="Котик 5" loading="lazy">
    <img src="https://cataas.com/cat?width=400&height=400&t=6" alt="Котик 6" loading="lazy">
  </div>
</body>
</html>
